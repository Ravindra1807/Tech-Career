            "date": 1783652879630,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Space+Mono:wght@400&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\r\n    <title>TechCareer Explorer - Data & Analytics</title>\r\n    <link rel=\"stylesheet\" href=\"CSS/data-a.css\">\r\n</head>\r\n\r\n<body>\r\n\r\n    <!-- ============ HEADER ============ -->\r\n\r\n    <header>\r\n\r\n        <a class=\"head-icon\" href=\"#\">\r\n\r\n            <div class=\"image-icon\">\r\n                <img src=\"images/Icon.png\" alt=\"TechCareer Explorer logo\" height=\"60\" width=\"60\">\r\n            </div>\r\n\r\n            <span class=\"nav-left\">TechCareer·Explorer</span>\r\n\r\n        </a>\r\n\r\n        <button class=\"menu-btn\" aria-label=\"Toggle navigation menu\">\r\n            <i class=\"fa fa-cog\"></i>\r\n        </button>\r\n\r\n        <ul class=\"navbar\" id=\"navLinks\">\r\n\r\n            <li>\r\n                <a class=\"nav-one\" href=\"index.html\">\r\n                    <i class=\"fa-solid fa-house\"></i>\r\n                    Home\r\n                </a>\r\n            </li>\r\n\r\n            <li class=\"dropdown\">\r\n\r\n                <a href=\"#\" class=\"nav-other dropdown-toggle\">\r\n                    <i class=\"fa-solid fa-briefcase\"></i>\r\n                    Category Roles\r\n                    <i class=\"fa-solid fa-chevron-down\"></i>\r\n                </a>\r\n\r\n                <ul class=\"dropdown-menu\">\r\n                    <li>\r\n                        <a href=\"web-development.html\"> Web Developer </a>\r\n                    </li>\r\n\r\n                    <li>\r\n                        <a href=\"mobile-development.html\"> Mobile Development</a>\r\n                    </li>\r\n\r\n                    <li>\r\n                        <a href=\"AIML.html\"> AI & Machine Learning</a>\r\n                    </li>\r\n\r\n                    <li>\r\n                        <a href=\"data-Analytics.html\"> Data & Analytics</a>\r\n                    </li>\r\n\r\n                    <li>\r\n                        <a href=\"UX_UX.html\"> UI/UX Design</a>\r\n                    </li>\r\n\r\n                    <li>\r\n                        <a href=\"cyber.html\">Cybersecurity</a>\r\n                    </li>\r\n\r\n                    <li>\r\n                        <a href=\"cloud&DevOps.html\">Cloud & DevOps</a>\r\n                    </li>\r\n\r\n                    <li>\r\n                        <a href=\"game-de.html\">Game Development</a>\r\n                    </li>\r\n\r\n                </ul>\r\n            </li>\r\n\r\n\r\n        </ul>\r\n\r\n\r\n\r\n    </header>\r\n\r\n    <!-- ============ HERO SECTION ============ -->\r\n    <div class=\"hero\">\r\n        <h1>Data & Analytics</h1>\r\n        <p>Transform raw data into actionable insights. Build careers in data analysis, data science, and business\r\n            intelligence.</p>\r\n    </div>\r\n\r\n    <!-- ============ MAIN CONTAINER ============ -->\r\n    <div class=\"container\">\r\n\r\n        <!-- ============ CAREER PATHS ============ -->\r\n        <section id=\"careers\">\r\n            <h2>Choose Your Data & Analytics Career Path</h2>\r\n            <div class=\"cards-container\">\r\n                <div class=\"card\">\r\n                    <h3>Data Analyst</h3>\r\n                    <p>Analyze data and create visualizations to help businesses make decisions.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>SQL</li>\r\n                        <li>Excel</li>\r\n                        <li>Tableau/Power BI</li>\r\n                        <li>Python/R</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Data Scientist</h3>\r\n                    <p>Build machine learning models and advanced statistical analysis for complex problems.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Python/R</li>\r\n                        <li>Machine Learning</li>\r\n                        <li>Statistics</li>\r\n                        <li>SQL</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Business Analyst</h3>\r\n                    <p>Bridge the gap between business and technology - analyze requirements and drive solutions.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>SQL</li>\r\n                        <li>Excel</li>\r\n                        <li>Business Logic</li>\r\n                        <li>Communication</li>\r\n                    </ul>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ DETAILED ROLES ============ -->\r\n        <section>\r\n            <h2>Data Analyst Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You collect, process, and analyze data to help organizations understand trends and make informed\r\n                    decisions. You create dashboards and reports.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>SQL - Query databases and extract data</li>\r\n                    <li>Excel - Advanced Excel skills with pivot tables</li>\r\n                    <li>Data Visualization - Tableau, Power BI, Looker</li>\r\n                    <li>Python/R - Statistical analysis</li>\r\n                    <li>Statistics - Understanding data patterns</li>\r\n                    <li>Business Acumen - Understanding business problems</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹4 - 14 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Data Analyst</li>\r\n                    <li>Business Intelligence Analyst</li>\r\n                    <li>Analytics Specialist</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Data Scientist Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You build predictive models and conduct advanced statistical analysis. You work with machine learning\r\n                    to solve complex business problems.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Python - Primary programming language</li>\r\n                    <li>Machine Learning - Supervised and unsupervised</li>\r\n                    <li>Statistics - Advanced statistics and probability</li>\r\n                    <li>SQL - Complex database queries</li>\r\n                    <li>Deep Learning - Neural networks, TensorFlow</li>\r\n                    <li>Data Engineering - Big data tools</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹6 - 20 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Data Scientist</li>\r\n                    <li>ML Engineer</li>\r\n                    <li>Analytics Engineer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Business Analyst Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You analyze business processes and gather requirements from stakeholders. You work with development\r\n                    teams to implement solutions.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>SQL - Database querying</li>\r\n                    <li>Excel - Advanced analysis</li>\r\n                    <li>Business Acumen - Understand business processes</li>\r\n                    <li>Communication - Excellent verbal and written</li>\r\n                    <li>Problem Solving - Analytical thinking</li>\r\n                    <li>Domain Knowledge - Industry-specific expertise</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹5 - 16 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Business Analyst</li>\r\n                    <li>Product Analyst</li>\r\n                    <li>Senior Analyst</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ SKILLS COMPARISON ============ -->\r\n        <section>\r\n            <h2>Skills Comparison Table</h2>\r\n            <div class=\"table-wrapper\">\r\n                <table>\r\n                    <thead>\r\n                        <tr>\r\n                            <th>Skills</th>\r\n                            <th>Data Analyst</th>\r\n                            <th>Data Scientist</th>\r\n                            <th>Business Analyst</th>\r\n                        </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                        <tr>\r\n                            <td>SQL</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Excel</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Data Visualization</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Python/R</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Machine Learning</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Statistics</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Business Acumen</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Communication</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                    </tbody>\r\n                </table>\r\n        </section>\r\n\r\n        <!-- ============ ROADMAP ============ -->\r\n        <section id=\"roadmap\">\r\n            <h2>Data & Analytics Learning Roadmap</h2>\r\n            <div class=\"roadmap-list\">\r\n                <h3>Step-by-Step Learning Path</h3>\r\n                <ol>\r\n                    <li><strong>Month 1-2:</strong> SQL fundamentals - database queries, joins, aggregations</li>\r\n                    <li><strong>Month 2-3:</strong> Excel mastery - pivot tables, formulas, advanced functions</li>\r\n                    <li><strong>Month 3-4:</strong> Data visualization - Tableau/Power BI basics</li>\r\n                    <li><strong>Month 4-5:</strong> Python basics - data manipulation with pandas, NumPy</li>\r\n                    <li><strong>Month 5-6:</strong> Statistics - probability, hypothesis testing, distributions</li>\r\n                    <li><strong>Month 6-7:</strong> Choose specialization - Analytics, Science, or Business</li>\r\n                    <li><strong>Month 7-9:</strong> Advanced topics - Machine learning or deep domain knowledge</li>\r\n                    <li><strong>Month 9-10:</strong> Build projects - portfolio building</li>\r\n                    <li><strong>Month 10+:</strong> Deploy & get job</li>\r\n                </ol>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ TECHNOLOGIES ============ -->\r\n        <section id=\"resources\">\r\n            <h2>Popular Technologies</h2>\r\n            <div class=\"tech-grid\">\r\n                <div class=\"tech-item\">SQL</div>\r\n                <div class=\"tech-item\">Excel</div>\r\n                <div class=\"tech-item\">Python</div>\r\n                <div class=\"tech-item\">R</div>\r\n                <div class=\"tech-item\">Tableau</div>\r\n                <div class=\"tech-item\">Power BI</div>\r\n                <div class=\"tech-item\">Google Analytics</div>\r\n                <div class=\"tech-item\">Looker</div>\r\n                <div class=\"tech-item\">Pandas</div>\r\n                <div class=\"tech-item\">Matplotlib</div>\r\n                <div class=\"tech-item\">Spark</div>\r\n                <div class=\"tech-item\">AWS/GCP</div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ PROJECT IDEAS ============ -->\r\n        <section>\r\n            <h2>Project Ideas to Practice</h2>\r\n            <div class=\"projects-grid\">\r\n                <div class=\"project-item\">Sales Analysis Dashboard</div>\r\n                <div class=\"project-item\">Customer Segmentation</div>\r\n                <div class=\"project-item\">Churn Prediction Model</div>\r\n                <div class=\"project-item\">Market Analysis Report</div>\r\n                <div class=\"project-item\">A/B Testing Analysis</div>\r\n                <div class=\"project-item\">Time Series Forecasting</div>\r\n                <div class=\"project-item\">Revenue Optimization</div>\r\n                <div class=\"project-item\">Cohort Analysis</div>\r\n            </div>\r\n        </section>\r\n\r\n\r\n        <section class=\"resources\">\r\n\r\n            <h3>📚 Free Learning Resources</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://www.kaggle.com/learn\" target=\"_blank\">Kaggle Learn</a></li>\r\n\r\n                <li><a href=\"https://www.w3schools.com/sql/\" target=\"_blank\">SQL Tutorial</a></li>\r\n\r\n                <li><a href=\"https://www.geeksforgeeks.org/data-science/\" target=\"_blank\">GeeksforGeeks Data Science</a>\r\n                </li>\r\n\r\n                <li><a href=\"https://roadmap.sh/data-analyst\" target=\"_blank\">Data Analyst Roadmap</a></li>\r\n\r\n                <li><a href=\"https://developers.google.com/machine-learning\" target=\"_blank\">Google Data & ML Guides</a>\r\n                </li>\r\n            </ul>\r\n\r\n            <h3>🎥 Free Video Tutorials</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://www.youtube.com/@AlexTheAnalyst\" target=\"_blank\">Alex The Analyst</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@Codebasics\" target=\"_blank\">Codebasics</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@KrishNaik06\" target=\"_blank\">Krish Naik</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@freecodecamp\" target=\"_blank\">freeCodeCamp</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@campusx-official\" target=\"_blank\">CampusX</a></li>\r\n            </ul>\r\n\r\n        </section>\r\n\r\n        <!-- ============ FAQ ============ -->\r\n        <section id=\"faq\">\r\n            <h2>Frequently Asked Questions</h2>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What's the difference between Data Analyst and Data Scientist?</h4>\r\n                <p>Data Analysts focus on analyzing existing data and creating reports. Data Scientists build predictive\r\n                    models using machine learning. Analysts use SQL and visualization, while Scientists use programming\r\n                    and statistics heavily.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What does a Business Analyst do?</h4>\r\n                <p>Business Analysts work with stakeholders to understand business needs and requirements. They bridge\r\n                    the gap between business teams and technical teams. They don't necessarily build models but help\r\n                    define what solutions are needed.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Which is easier to start - Data Analyst or Data Scientist?</h4>\r\n                <p>Data Analyst is easier - you need SQL, Excel, and visualization skills. Data Scientist requires\r\n                    Python, Machine Learning, and advanced statistics. Most people start as Data Analyst and move to\r\n                    Data Scientist.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>How long does it take to learn Data Analytics?</h4>\r\n                <p>Basics: 3-4 months. Intermediate: 6-8 months. Professional level: 1-2 years. It depends on your\r\n                    background and daily practice time.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Do I need a statistics degree for Data Analytics?</h4>\r\n                <p>No. Many successful data professionals are self-taught. What matters is your practical skills,\r\n                    portfolio, and ability to solve business problems. Online courses are enough.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What tools should I learn first?</h4>\r\n                <p>Start with SQL and Excel - they are most essential. Then learn a visualization tool (Tableau or Power\r\n                    BI). Then Python for more advanced analysis. This progression will help you build stronger\r\n                    foundations.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What companies hire Data professionals in India?</h4>\r\n                <p>Amazon, Flipkart, Google, Microsoft, Facebook, LinkedIn, Airbnb, Netflix, and many startups. All\r\n                    companies need data professionals. Remote jobs are abundant.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What's the salary growth in Data Analytics?</h4>\r\n                <p>Fresher: ₹3-5 LPA. 2-3 years: ₹6-10 LPA. 5+ years: ₹15-25 LPA. With specialization (Data Science),\r\n                    you can earn more.</p>\r\n            </div>\r\n        </section>\r\n\r\n    </div>\r\n\r\n    <!-- ============ FOOTER ============ -->\r\n    <footer class=\"footer\">\r\n        <div class=\"footer-container\">\r\n\r\n            <div class=\"footer-box\">\r\n                <div class=\"U\">\r\n                    <h2>Tech Career</h2>\r\n                    <p>\r\n                        Discover technology careers, explore learning paths,\r\n                        and build your future in the tech industry.\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Quick Links</h3>\r\n                <ul>\r\n                    <li><a href=\"index.html\">➤ Home</a></li>\r\n                    <li><a href=\"index.html\">➤ Careers</a></li>\r\n                    <li><a href=\"index.html\">➤ Roadmaps</a></li>\r\n                    <li><a href=\"index.html\">➤ Resources</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Specializations</h3>\r\n                <ul>\r\n                    <li><a href=\"web-development.html\">➤ Web Development</a></li>\r\n                    <li><a href=\"mobile-development.html\">➤ Mobile Development</a></li>\r\n                    <li><a href=\"AIML.html\">➤ AI & ML</a></li>\r\n                    <li><a href=\"data-Analytics.html\">➤ Data & Analytics</a></li>\r\n                    <li><a href=\"UX_UX.html\">➤ UI/UX Design</a></li>\r\n                    <li><a href=\"cyber.html\">➤ Cybersecurity</a></li>\r\n                    <li><a href=\"cloud&DevOps.html\">➤ Cloud & DevOps</a></li>\r\n                    <li><a href=\"game-de.html\">➤ Game Development</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n           <div class=\"footer-box\">\r\n                <h3>Contact</h3>\r\n                <ul>\r\n                    <li><i class=\"fa-solid fa-envelope\"></i> : <a\r\n                            href=\"mailto:rk8938273@gmail.com\" target=\"_blank\">rk8938273@gmail.com</a></li>\r\n                    <li><i class=\"fa-solid fa-phone\"></i> : <a href=\"tel:+919876543210\"  target=\"_blank\">+91 9876543210</a></li>\r\n                    <li><i class=\"fa-brands fa-github\"></i> : <a href=\"https://github.com/Ravindra1807\"  target=\"_blank\">Ravindra1807</a>\r\n                    </li>\r\n                    <li><i class=\"fa-brands fa-linkedin\"></i> : <a\r\n                            href=\"https://www.linkedin.com/in/ravindra-kumar-a95761385\" target=\"_blank\">Ravindra Kumar</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n        </div>\r\n\r\n        <div class=\"footer-bottom\">\r\n            <p>© 2026 Tech Career Explorer. All Rights Reserved. | Developed by Ravindra Kumar</p>\r\n        </div>\r\n    </footer>\r\n\r\n    <script>\r\n        const menuBtn = document.querySelector(\".menu-btn\");\r\n        const navLinks = document.querySelector(\"#navLinks\");\r\n        const dropdowns = document.querySelectorAll(\".dropdown\");\r\n\r\n        // Mobile hamburger toggle\r\n        menuBtn.addEventListener(\"click\", (e) => {\r\n            e.stopPropagation();\r\n            navLinks.classList.toggle(\"active\");\r\n        });\r\n\r\n        // Close navbar + all dropdowns on outside click\r\n        document.addEventListener(\"click\", (e) => {\r\n            if (!navLinks.contains(e.target) && !menuBtn.contains(e.target)) {\r\n                navLinks.classList.remove(\"active\");\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n            }\r\n        });\r\n\r\n        // Dropdown toggle — 1 click open, same click close\r\n        dropdowns.forEach((dropdown) => {\r\n            const toggle = dropdown.querySelector(\".dropdown-toggle\");\r\n\r\n            toggle.addEventListener(\"click\", (e) => {\r\n                e.preventDefault();\r\n                e.stopPropagation();\r\n\r\n                const isOpen = dropdown.classList.contains(\"open\");\r\n\r\n                // close all first\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n\r\n                // toggle this one\r\n                if (!isOpen) dropdown.classList.add(\"open\");\r\n            });\r\n        });\r\n\r\n        // Clicks inside dropdown-menu don't close it\r\n        document.querySelectorAll(\".dropdown-menu\").forEach((menu) => {\r\n            menu.addEventListener(\"click\", (e) => e.stopPropagation());\r\n        });\r\n    </script>\r\n</body>\r\n\r\n</html>"
        }
    ]
}