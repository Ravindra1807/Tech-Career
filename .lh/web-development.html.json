            "date": 1783652892875,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Space+Mono:wght@400&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\r\n    <link rel=\"stylesheet\" href=\"CSS/web-development.css\">\r\n    <title>Web-Development</title>\r\n</head>\r\n\r\n<body>\r\n\r\n    <!-- ============ HEADER ============ -->\r\n    <header>\r\n\r\n        <a class=\"head-icon\" href=\"#\">\r\n            <div class=\"image-icon\">\r\n                <img src=\"images/Icon.png\" alt=\"TechCareer Explorer logo\" height=\"60\" width=\"60\">\r\n            </div>\r\n            <span class=\"nav-left\">TechCareer·Explorer</span>\r\n        </a>\r\n\r\n        <button class=\"menu-btn\" aria-label=\"Toggle navigation menu\">\r\n            <i class=\"fa fa-cog\"></i>\r\n         </button>\r\n\r\n        <ul class=\"navbar\" id=\"navLinks\">\r\n\r\n            <li>\r\n                <a class=\"nav-one\" href=\"index.html\">\r\n                    <i class=\"fa-solid fa-house\"></i>\r\n                    Home\r\n                </a>\r\n            </li>\r\n\r\n            <li class=\"dropdown\">\r\n                <a href=\"#\" class=\"nav-other dropdown-toggle\">\r\n                    <i class=\"fa-solid fa-briefcase\"></i>\r\n                    Category Roles\r\n                    <i class=\"fa-solid fa-chevron-down\"></i>\r\n                </a>\r\n                 <ul class=\"dropdown-menu\">\r\n                    <li>\r\n                        <a href=\"web-development.html\"> Web Developer </a>\r\n                    </li>\r\n\r\n                    <li>\r\n                        <a href=\"mobile-development.html\"> Mobile Development</a>\r\n                    </li>\r\n\r\n                    <li>\r\n                        <a href=\"AIML.html\"> AI & Machine Learning</a>\r\n                    </li>\r\n\r\n                    <li>\r\n                        <a href=\"data-Analytics.html\"> Data & Analytics</a>\r\n                    </li>\r\n\r\n                    <li>\r\n                        <a href=\"UX_UX.html\"> UI/UX Design</a>\r\n                    </li>\r\n\r\n                    <li> \r\n                        <a href=\"cyber.html\">Cybersecurity</a>\r\n                    </li>\r\n\r\n                    <li> \r\n                        <a href=\"cloud&DevOps.html\">Cloud & DevOps</a>\r\n                    </li>\r\n\r\n                    <li> \r\n                        <a href=\"game-de.html\">Game Development</a>\r\n                    </li>\r\n\r\n                </ul>\r\n            </li>\r\n\r\n\r\n        </ul>\r\n\r\n\r\n\r\n    </header>\r\n\r\n    <!-- ============ HERO SECTION ============ -->\r\n    <div class=\"hero\">\r\n        <h1>Web Development</h1>\r\n        <p>Build modern websites and web applications using Frontend, Backend and Full Stack technologies.</p>\r\n    </div>\r\n\r\n    <!-- ============ MAIN CONTAINER ============ -->\r\n    <div class=\"container\">\r\n\r\n        <!-- ============ CAREER PATHS ============ -->\r\n        <section id=\"careers\">\r\n            <h2>Choose Your Career Path</h2>\r\n            <div class=\"cards-container\">\r\n                <div class=\"card\">\r\n                    <h3>Frontend Developer</h3>\r\n                    <p>Build the user interface and user experience of websites.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>HTML</li>\r\n                        <li>CSS</li>\r\n                        <li>JavaScript</li>\r\n                        <li>React</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Backend Developer</h3>\r\n                    <p>Build the server, APIs and database that power applications.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Java</li>\r\n                        <li>Node.js</li>\r\n                        <li>SQL</li>\r\n                        <li>API Design</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Full Stack Developer</h3>\r\n                    <p>Work on both frontend and backend to build complete applications.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Frontend</li>\r\n                        <li>Backend</li>\r\n                        <li>Database</li>\r\n                        <li>Deployment</li>\r\n                    </ul>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ DETAILED ROLES ============ -->\r\n        <section>\r\n            <h2>Frontend Developer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You build what users see and interact with. You create beautiful, responsive websites using HTML,\r\n                    CSS, and JavaScript.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>HTML - Structure of web pages</li>\r\n                    <li>CSS - Styling and responsive design</li>\r\n                    <li>JavaScript - Interactivity and logic</li>\r\n                    <li>React or Vue - Modern frameworks</li>\r\n                    <li>Git - Version control</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹4 - 12 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Junior Frontend Developer</li>\r\n                    <li>React Developer</li>\r\n                    <li>Frontend Engineer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Backend Developer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You build the logic, APIs and databases. You handle the server-side code that powers web\r\n                    applications.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Java / Python / Node.js - Programming languages</li>\r\n                    <li>Spring Boot / Express - Frameworks</li>\r\n                    <li>SQL / MongoDB - Databases</li>\r\n                    <li>REST API Design</li>\r\n                    <li>Authentication & Security</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹5 - 15 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Backend Developer</li>\r\n                    <li>API Developer</li>\r\n                    <li>Database Administrator</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Full Stack Developer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You work on both frontend and backend. You build complete applications from user interface to\r\n                    database.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Frontend - HTML, CSS, JavaScript, React</li>\r\n                    <li>Backend - Node.js or Java</li>\r\n                    <li>Databases - MySQL, MongoDB</li>\r\n                    <li>REST APIs</li>\r\n                    <li>Git & Deployment</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹6 - 18 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Full Stack Developer</li>\r\n                    <li>Full Stack Engineer</li>\r\n                    <li>Web Developer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n\r\n        \r\n<section>\r\n    <h2>Skills Comparison Table</h2>\r\n    <div class=\"table-wrapper\">\r\n        <table>\r\n            <thead>\r\n                <tr>\r\n                     <th>Skills</th>\r\n                        <th>Frontend</th>\r\n                        <th>Backend</th>\r\n                        <th>Full Stack</th>\r\n                </tr>\r\n            </thead>\r\n             <tbody>\r\n                    <tr>\r\n                        <td>HTML</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"cross\">✗</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>CSS</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"cross\">✗</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>JavaScript</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Database (SQL/NoSQL)</td>\r\n                        <td class=\"cross\">✗</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>REST APIs</td>\r\n                        <td class=\"cross\">✗</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Git & Version Control</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Deployment</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                        <td class=\"checkmark\">✓</td>\r\n                    </tr>\r\n                </tbody>\r\n        </table>\r\n    </div>\r\n</section>\r\n\r\n        <!-- ============ SKILLS COMPARISON ============ -->\r\n      \r\n\r\n        <!-- ============ ROADMAP ============ -->\r\n        <section id=\"roadmap\">\r\n            <h2>Web Development Roadmap</h2>\r\n            <div class=\"roadmap-list\">\r\n                <h3>Step-by-Step Learning Path</h3>\r\n                <ol>\r\n                    <li><strong>Month 1-2:</strong> Learn HTML basics - structure and semantic elements</li>\r\n                    <li><strong>Month 2-3:</strong> Learn CSS - styling, layouts, responsive design</li>\r\n                    <li><strong>Month 3-4:</strong> Learn JavaScript - variables, functions, DOM manipulation</li>\r\n                    <li><strong>Month 4-5:</strong> Choose path - Frontend (React/Vue) or Backend (Node.js/Java)</li>\r\n                    <li><strong>Month 5-6:</strong> Learn databases - MySQL or MongoDB</li>\r\n                    <li><strong>Month 6-7:</strong> Build projects - create real-world applications</li>\r\n                    <li><strong>Month 7+:</strong> Specialize - deep dive into your chosen area</li>\r\n                </ol>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ TECHNOLOGIES ============ -->\r\n        <section id=\"resources\">\r\n            <h2>Popular Technologies</h2>\r\n            <div class=\"tech-grid\">\r\n                <div class=\"tech-item\">HTML5</div>\r\n                <div class=\"tech-item\">CSS3</div>\r\n                <div class=\"tech-item\">JavaScript</div>\r\n                <div class=\"tech-item\">React</div>\r\n                <div class=\"tech-item\">Vue.js</div>\r\n                <div class=\"tech-item\">Node.js</div>\r\n                <div class=\"tech-item\">Java</div>\r\n                <div class=\"tech-item\">Python</div>\r\n                <div class=\"tech-item\">MySQL</div>\r\n                <div class=\"tech-item\">MongoDB</div>\r\n                <div class=\"tech-item\">Git</div>\r\n                <div class=\"tech-item\">Docker</div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ PROJECT IDEAS ============ -->\r\n        <section>\r\n            <h2>Project Ideas to Practice</h2>\r\n            <div class=\"projects-grid\">\r\n                <div class=\"project-item\">Portfolio Website</div>\r\n                <div class=\"project-item\">Todo App</div>\r\n                <div class=\"project-item\">Weather App</div>\r\n                <div class=\"project-item\">Calculator</div>\r\n                <div class=\"project-item\">E-Commerce Site</div>\r\n                <div class=\"project-item\">Chat Application</div>\r\n                <div class=\"project-item\">Blog Website</div>\r\n                <div class=\"project-item\">Social Media Clone</div>\r\n            </div>\r\n        </section>\r\n\r\n        <section class=\"resources\">\r\n\r\n            <h3>📚 Free Learning Resources</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://developer.mozilla.org/\" target=\"_blank\">MDN Web Docs</a></li>\r\n\r\n                <li><a href=\"https://www.w3schools.com/\" target=\"_blank\">W3Schools</a></li>\r\n\r\n                <li><a href=\"https://www.freecodecamp.org/\" target=\"_blank\">freeCodeCamp</a></li>\r\n\r\n                <li><a href=\"https://www.geeksforgeeks.org/web-development/\" target=\"_blank\">GeeksforGeeks Web\r\n                        Development</a></li>\r\n\r\n                <li><a href=\"https://roadmap.sh/frontend\" target=\"_blank\">Frontend Roadmap</a></li>\r\n            </ul>\r\n\r\n            <h3>🎥 Free Video Tutorials</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://www.youtube.com/@CodeWithHarry\" target=\"_blank\">CodeWithHarry</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@ApnaCollegeOfficial\" target=\"_blank\">Apna College</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@chaiaurcode\" target=\"_blank\">Chai Aur Code</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@TraversyMedia\" target=\"_blank\">Traversy Media</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@freecodecamp\" target=\"_blank\">freeCodeCamp YouTube</a></li>\r\n            </ul>\r\n\r\n        </section>\r\n\r\n        <!-- ============ FAQ ============ -->\r\n        <section id=\"faq\">\r\n            <h2>Frequently Asked Questions</h2>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What is Frontend Development?</h4>\r\n                <p>Frontend development involves building the user interface (UI) and user experience (UX) of websites.\r\n                    It uses HTML for structure, CSS for styling, and JavaScript for interactivity.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What is Backend Development?</h4>\r\n                <p>Backend development involves building the server-side of applications. It handles databases, APIs,\r\n                    authentication, and business logic that users don't directly see.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What is Full Stack Development?</h4>\r\n                <p>Full stack developers work on both frontend and backend. They can build complete web applications\r\n                    from the user interface to the database.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>How long does it take to learn web development?</h4>\r\n                <p>You can learn basics in 3-6 months with consistent practice. Becoming proficient takes 6-12 months.\r\n                    Mastery and specialization typically takes 1-2 years.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Do I need a degree to become a web developer?</h4>\r\n                <p>No, many successful developers are self-taught. What matters is your skills, portfolio, and practical\r\n                    experience. Building projects is more important than degrees.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What's the average salary of a web developer in India?</h4>\r\n                <p>Fresher developers earn ₹2-5 LPA. With experience, it can go up to ₹15-30 LPA or more. Salary depends\r\n                    on skills, experience, location, and company size.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Where should I start learning?</h4>\r\n                <p>Start with HTML and CSS basics using free resources like freeCodeCamp or W3Schools. Then move to\r\n                    JavaScript. Build small projects as you learn.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Is web development a good career?</h4>\r\n                <p>Yes! Web development has high demand, good salaries, remote job opportunities, and constant learning\r\n                    opportunities. It's a great career choice.</p>\r\n            </div>\r\n        </section>\r\n\r\n    </div>\r\n\r\n    <!-- ============ FOOTER ============ -->\r\n    <footer class=\"footer\">\r\n        <div class=\"footer-container\">\r\n\r\n            <div class=\"footer-box\">\r\n                <div class=\"U\">\r\n                    <h2>Tech Career</h2>\r\n                    <p>\r\n                        Discover technology careers, explore learning paths,\r\n                        and build your future in the tech industry.\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Quick Links</h3>\r\n                <ul>\r\n                    <li><a href=\"index.html\">➤ Home</a></li>\r\n                    <li><a href=\"index.html\">➤ Careers</a></li>\r\n                    <li><a href=\"index.html\">➤ Roadmaps</a></li>\r\n                    <li><a href=\"index.html\">➤ Resources</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Specializations</h3>\r\n                <ul>\r\n                    <li><a href=\"web-development.html\">➤ Web Development</a></li>\r\n                    <li><a href=\"mobile-development.html\">➤ Mobile Development</a></li>\r\n                    <li><a href=\"AIML.html\">➤ AI & ML</a></li>\r\n                    <li><a href=\"data-Analytics.html\">➤ Data & Analytics</a></li>\r\n                    <li><a href=\"UX_UX.html\">➤ UI/UX Design</a></li>\r\n                    <li><a href=\"cyber.html\">➤ Cybersecurity</a></li>\r\n                    <li><a href=\"cloud&DevOps.html\">➤ Cloud & DevOps</a></li>\r\n                    <li><a href=\"game-de.html\">➤ Game Development</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n          <div class=\"footer-box\">\r\n                <h3>Contact</h3>\r\n                <ul>\r\n                    <li><i class=\"fa-solid fa-envelope\"></i> : <a\r\n                            href=\"mailto:rk8938273@gmail.com\" target=\"_blank\">rk8938273@gmail.com</a></li>\r\n                    <li><i class=\"fa-solid fa-phone\"></i> : <a href=\"tel:+919876543210\"  target=\"_blank\">+91 9876543210</a></li>\r\n                    <li><i class=\"fa-brands fa-github\"></i> : <a href=\"https://github.com/Ravindra1807\"  target=\"_blank\">Ravindra1807</a>\r\n                    </li>\r\n                    <li><i class=\"fa-brands fa-linkedin\"></i> : <a\r\n                            href=\"https://www.linkedin.com/in/ravindra-kumar-a95761385\" target=\"_blank\">Ravindra Kumar</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n        </div>\r\n\r\n        <div class=\"footer-bottom\">\r\n            <p>© 2026 Tech Career Explorer. All Rights Reserved. | Developed by Ravindra Kumar</p>\r\n        </div>\r\n    </footer>\r\n\r\n     <script>\r\n        const menuBtn = document.querySelector(\".menu-btn\");\r\n        const navLinks = document.querySelector(\"#navLinks\");\r\n        const dropdowns = document.querySelectorAll(\".dropdown\");\r\n\r\n        // Mobile hamburger toggle\r\n        menuBtn.addEventListener(\"click\", (e) => {\r\n            e.stopPropagation();\r\n            navLinks.classList.toggle(\"active\");\r\n        });\r\n\r\n        // Close navbar + all dropdowns on outside click\r\n        document.addEventListener(\"click\", (e) => {\r\n            if (!navLinks.contains(e.target) && !menuBtn.contains(e.target)) {\r\n                navLinks.classList.remove(\"active\");\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n            }\r\n        });\r\n\r\n        // Dropdown toggle — 1 click open, same click close\r\n        dropdowns.forEach((dropdown) => {\r\n            const toggle = dropdown.querySelector(\".dropdown-toggle\");\r\n\r\n            toggle.addEventListener(\"click\", (e) => {\r\n                e.preventDefault();\r\n                e.stopPropagation();\r\n\r\n                const isOpen = dropdown.classList.contains(\"open\");\r\n\r\n                // close all first\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n\r\n                // toggle this one\r\n                if (!isOpen) dropdown.classList.add(\"open\");\r\n            });\r\n        });\r\n\r\n        // Clicks inside dropdown-menu don't close it\r\n        document.querySelectorAll(\".dropdown-menu\").forEach((menu) => {\r\n            menu.addEventListener(\"click\", (e) => e.stopPropagation());\r\n        });\r\n    </script>\r\n\r\n\r\n</body>\r\n\r\n</html>"
        }
    ]
}