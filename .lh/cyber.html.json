            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Space+Mono:wght@400&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\r\n    <link\r\n        href=\"https://fonts.googleapis.com/css2?family=Black+Ops+One&family=DM+Serif+Display:ital@0;1&family=Electrolize&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap\">\r\n    <title>Cybersecurity - TechCareer Explorer</title>\r\n<link rel=\"stylesheet\" href=\"CSS/cyber.css\">\r\n</head>\r\n\r\n<body>\r\n\r\n    <!-- ============ HEADER ============ -->\r\n    <header>\r\n        <a class=\"head-icon\" href=\"#\">\r\n            <div class=\"image-icon\">\r\n                <img src=\"images/Icon.png\" alt=\"TechCareer Explorer logo\" height=\"60\" width=\"60\">\r\n            </div>\r\n            <span class=\"nav-left\">TechCareer·Explorer</span>\r\n        </a>\r\n\r\n        <button class=\"menu-btn\" aria-label=\"Toggle navigation menu\">\r\n            <i class=\"fa fa-cog\"></i>\r\n        </button>\r\n\r\n        <ul class=\"navbar\" id=\"navLinks\">\r\n            <li>\r\n                <a class=\"nav-one\" href=\"index.html\">\r\n                    <i class=\"fa-solid fa-house\"></i>\r\n                    Home\r\n                </a>\r\n            </li>\r\n\r\n            <li class=\"dropdown\">\r\n                <a href=\"#\" class=\"nav-other dropdown-toggle\">\r\n                    <i class=\"fa-solid fa-briefcase\"></i>\r\n                    Category Roles\r\n                    <i class=\"fa-solid fa-chevron-down\"></i>\r\n                </a>\r\n                <ul class=\"dropdown-menu\">\r\n                    <li><a href=\"web-development.html\">Web Developer</a></li>\r\n                    <li><a href=\"mobile-development.html\">Mobile Development</a></li>\r\n                    <li><a href=\"AIML.html\">AI & Machine Learning</a></li>\r\n                    <li><a href=\"data-Analytics.html\">Data & Analytics</a></li>\r\n                    <li><a href=\"UX_UX.html\">UI/UX Design</a></li>\r\n                    <li><a href=\"cyber.html\">Cybersecurity</a></li>\r\n                    <li><a href=\"cloud&DevOps.html\">Cloud & DevOps</a></li>\r\n                    <li><a href=\"game-de.html\">Game Development</a></li>\r\n                </ul>\r\n            </li>\r\n        </ul>\r\n    </header>\r\n\r\n    <!-- ============ HERO SECTION ============ -->\r\n    <div class=\"hero\">\r\n        <h1>Cybersecurity</h1>\r\n        <p>Protect digital assets and systems. Master Security Analysis, Ethical Hacking, Network Security, and Threat\r\n            Management.</p>\r\n    </div>\r\n\r\n    <!-- ============ MAIN CONTAINER ============ -->\r\n    <div class=\"container\">\r\n\r\n        <!-- ============ CAREER PATHS ============ -->\r\n        <section id=\"careers\">\r\n            <h2>Choose Your Career Path</h2>\r\n            <div class=\"cards-container\">\r\n                <div class=\"card\">\r\n                    <h3>Security Analyst</h3>\r\n                    <p>Monitor systems and networks to detect security threats and vulnerabilities.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>SIEM Tools</li>\r\n                        <li>Threat Detection</li>\r\n                        <li>Network Analysis</li>\r\n                        <li>Log Management</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Ethical Hacker</h3>\r\n                    <p>Test systems for vulnerabilities to improve security before attackers find them.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Penetration Testing</li>\r\n                        <li>Vulnerability Assessment</li>\r\n                        <li>Security Tools</li>\r\n                        <li>Exploit Development</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Security Engineer</h3>\r\n                    <p>Design, implement, and maintain security systems and infrastructure.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Firewalls & IDS/IPS</li>\r\n                        <li>Encryption</li>\r\n                        <li>Architecture Design</li>\r\n                        <li>Cloud Security</li>\r\n                    </ul>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ DETAILED ROLES ============ -->\r\n        <section>\r\n            <h2>Security Analyst Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You monitor and analyze security events across networks and systems. You identify potential threats,\r\n                    respond to incidents, and create security reports to protect organizational assets.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>SIEM Tools - Splunk, ELK, Sumo Logic</li>\r\n                    <li>Network Analysis - Wireshark, tcpdump</li>\r\n                    <li>Threat Detection & Analysis - IDS/IPS</li>\r\n                    <li>Linux & Windows - OS knowledge</li>\r\n                    <li>Scripting - Python, Bash</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹5 - 12 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Junior Security Analyst</li>\r\n                    <li>SOC Analyst</li>\r\n                    <li>Threat Intelligence Analyst</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Ethical Hacker Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You conduct penetration tests and vulnerability assessments to identify security weaknesses. You work\r\n                    with companies to find and document vulnerabilities before malicious actors can exploit them.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Penetration Testing - Methodology & Tools</li>\r\n                    <li>Kali Linux - Hacking Operating System</li>\r\n                    <li>Security Tools - Metasploit, Burp Suite, Nmap</li>\r\n                    <li>Programming - Python, C, Java</li>\r\n                    <li>Web Security - OWASP Top 10</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹6 - 15 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Ethical Hacker / Penetration Tester</li>\r\n                    <li>Security Researcher</li>\r\n                    <li>Vulnerability Assessor</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Security Engineer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You design and implement comprehensive security solutions. You architect security systems, manage\r\n                    firewalls, deploy encryption, and ensure systems follow security best practices.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Network Security - Firewalls, VPN, IDS/IPS</li>\r\n                    <li>Cloud Security - AWS, Azure, GCP security</li>\r\n                    <li>Encryption & Cryptography - PKI, SSL/TLS</li>\r\n                    <li>Security Architecture - Design & Implementation</li>\r\n                    <li>Compliance - GDPR, HIPAA, PCI-DSS</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹8 - 20 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Security Engineer</li>\r\n                    <li>Cloud Security Engineer</li>\r\n                    <li>Infrastructure Security Engineer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ SKILLS COMPARISON ============ -->\r\n        <section>\r\n            <h2>Skills Comparison Table</h2>\r\n            <div class=\"table-wrapper\">\r\n                <table>\r\n                    <thead>\r\n                        <tr>\r\n                            <th>Skills</th>\r\n                            <th>Security Analyst</th>\r\n                            <th>Ethical Hacker</th>\r\n                            <th>Security Engineer</th>\r\n                        </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                        <tr>\r\n                            <td>Network Knowledge</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Linux / Windows</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>SIEM Tools</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Penetration Testing</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Security Tools (Metasploit, Burp)</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Threat Detection & Analysis</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Programming (Python/C)</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Architecture & Design</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Cloud Security (AWS/Azure)</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Cryptography & Encryption</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                    </tbody>\r\n                </table>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ ROADMAP ============ -->\r\n        <section id=\"roadmap\">\r\n            <h2>Cybersecurity Learning Roadmap</h2>\r\n            <div class=\"roadmap-list\">\r\n                <h3>Step-by-Step Learning Path</h3>\r\n                <ol>\r\n                    <li><strong>Month 1-2:</strong> Learn networking fundamentals - TCP/IP, OSI Model, DNS, HTTP</li>\r\n                    <li><strong>Month 2-3:</strong> Learn Linux & Windows administration - command line, users,\r\n                        permissions</li>\r\n                    <li><strong>Month 3-4:</strong> Study security basics - cryptography, authentication, encryption\r\n                    </li>\r\n                    <li><strong>Month 4-5:</strong> Choose specialization - learn SIEM, Penetration Testing, or\r\n                        Architecture</li>\r\n                    <li><strong>Month 5-6:</strong> Get hands-on with security tools - Wireshark, Kali Linux, Burp Suite\r\n                    </li>\r\n                    <li><strong>Month 6-7:</strong> Build projects & lab environments - set up home labs, do practice\r\n                        tests</li>\r\n                    <li><strong>Month 7+:</strong> Get certified & specialize - CompTIA, CEH, OSCP certifications</li>\r\n                </ol>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ TECHNOLOGIES ============ -->\r\n        <section id=\"resources\">\r\n            <h2>Popular Security Tools & Technologies</h2>\r\n            <div class=\"tech-grid\">\r\n                <div class=\"tech-item\">Kali Linux</div>\r\n                <div class=\"tech-item\">Metasploit</div>\r\n                <div class=\"tech-item\">Wireshark</div>\r\n                <div class=\"tech-item\">Burp Suite</div>\r\n                <div class=\"tech-item\">Nmap</div>\r\n                <div class=\"tech-item\">Splunk</div>\r\n                <div class=\"tech-item\">Snort/Suricata</div>\r\n                <div class=\"tech-item\">OWASP</div>\r\n                <div class=\"tech-item\">Hashcat</div>\r\n                <div class=\"tech-item\">Nikto</div>\r\n                <div class=\"tech-item\">John the Ripper</div>\r\n                <div class=\"tech-item\">AWS Security</div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ PROJECT IDEAS ============ -->\r\n        <section>\r\n            <h2>Project Ideas to Practice</h2>\r\n            <div class=\"projects-grid\">\r\n                <div class=\"project-item\">Vulnerability Scan</div>\r\n                <div class=\"project-item\">Penetration Test Report</div>\r\n                <div class=\"project-item\">Network Sniffer</div>\r\n                <div class=\"project-item\">Password Cracker</div>\r\n                <div class=\"project-item\">Malware Analysis</div>\r\n                <div class=\"project-item\">Firewall Configuration</div>\r\n                <div class=\"project-item\">Threat Hunting Lab</div>\r\n                <div class=\"project-item\">Security Audit</div>\r\n            </div>\r\n        </section>\r\n\r\n        <section class=\"resources\">\r\n\r\n            <h3>📚 Free Learning Resources</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://www.offensive-security.com/\" target=\"_blank\">Offensive Security</a></li>\r\n\r\n                <li><a href=\"https://www.elearnsecurity.com/\" target=\"_blank\">eLearnsecurity</a></li>\r\n\r\n                <li><a href=\"https://www.hackthebox.com/\" target=\"_blank\">HackTheBox</a></li>\r\n\r\n                <li><a href=\"https://tryhackme.com/\" target=\"_blank\">TryHackMe</a></li>\r\n\r\n                <li><a href=\"https://owasp.org/\" target=\"_blank\">OWASP</a></li>\r\n            </ul>\r\n\r\n            <h3>🎥 Free Video Tutorials</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://www.youtube.com/@JohnHammondSec\" target=\"_blank\">John Hammond</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@IppSec\" target=\"_blank\">IppSec</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@PentesterAcademyTV\" target=\"_blank\">Pentester Academy</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@NetworkChuck\" target=\"_blank\">NetworkChuck</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@StrykerHS\" target=\"_blank\">Stryker</a></li>\r\n            </ul>\r\n\r\n        </section>\r\n\r\n        <!-- ============ FAQ ============ -->\r\n        <section id=\"faq\">\r\n            <h2>Frequently Asked Questions</h2>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What is Security Analysis?</h4>\r\n                <p>Security Analysis involves monitoring systems and networks for threats, analyzing security events,\r\n                    and creating reports. Security Analysts work in Security Operations Centers (SOC) to detect and\r\n                    respond to incidents.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What is Ethical Hacking?</h4>\r\n                <p>Ethical Hacking is authorized security testing where professionals attempt to break into systems\r\n                    legally to find vulnerabilities before malicious hackers can. It requires permission and is done to\r\n                    improve security.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What is a Security Engineer?</h4>\r\n                <p>Security Engineers design and implement security solutions. They build secure infrastructure,\r\n                    implement firewalls, manage encryption, and ensure systems follow security best practices and\r\n                    compliance standards.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Do I need certifications to start a cybersecurity career?</h4>\r\n                <p>Certifications help, but practical experience is more important. Start with CompTIA Security+, CEH,\r\n                    or OSCP. Entry-level roles focus on skills and projects. Certifications become more important as you\r\n                    advance.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>How long does it take to learn cybersecurity?</h4>\r\n                <p>Basics take 3-4 months. Job-ready skills take 6-12 months of focused study and practice. Becoming\r\n                    specialized typically takes 1-2 years. Continuous learning is essential as threats evolve.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What's the average salary of a cybersecurity professional in India?</h4>\r\n                <p>Fresher analysts earn ₹3-6 LPA. Mid-level professionals earn ₹10-18 LPA. Senior roles earn ₹20-40+\r\n                    LPA. Salary depends on role, experience, certifications, and company size.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Is cybersecurity a good career choice?</h4>\r\n                <p>Yes! Cybersecurity has high demand, excellent salaries, remote opportunities, and job security. With\r\n                    increasing cyber threats, security professionals are always needed. It's a rewarding and challenging\r\n                    career.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What should I learn first - networking, Linux, or security?</h4>\r\n                <p>Start with networking fundamentals (TCP/IP, DNS). Then learn Linux administration. Finally, dive into\r\n                    security concepts. A strong foundation in networking is essential for cybersecurity success.</p>\r\n            </div>\r\n        </section>\r\n\r\n    </div>\r\n\r\n    <!-- ============ FOOTER ============ -->\r\n    <footer class=\"footer\">\r\n        <div class=\"footer-container\">\r\n\r\n            <div class=\"footer-box\">\r\n                <div class=\"U\">\r\n                    <h2>Tech Career</h2>\r\n                    <p>\r\n                        Discover technology careers, explore learning paths,\r\n                        and build your future in the tech industry.\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Quick Links</h3>\r\n                <ul>\r\n                    <li><a href=\"index.html\">➤ Home</a></li>\r\n                    <li><a href=\"index.html\">➤ Careers</a></li>\r\n                    <li><a href=\"index.html\">➤ Roadmaps</a></li>\r\n                    <li><a href=\"index.html\">➤ Resources</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Specializations</h3>\r\n                <ul>\r\n                    <li><a href=\"web-development.html\">➤ Web Development</a></li>\r\n                    <li><a href=\"mobile-development.html\">➤ Mobile Development</a></li>\r\n                    <li><a href=\"AIML.html\">➤ AI & ML</a></li>\r\n                    <li><a href=\"data-Analytics.html\">➤ Data & Analytics</a></li>\r\n                    <li><a href=\"UX_UX.html\">➤ UI/UX Design</a></li>\r\n                    <li><a href=\"cyber.html\">➤ Cybersecurity</a></li>\r\n                    <li><a href=\"cloud&DevOps.html\">➤ Cloud & DevOps</a></li>\r\n                    <li><a href=\"game-de.html\">➤ Game Development</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n          <div class=\"footer-box\">\r\n                <h3>Contact</h3>\r\n                <ul>\r\n                    <li><i class=\"fa-solid fa-envelope\"></i> : <a\r\n                            href=\"mailto:rk8938273@gmail.com\" target=\"_blank\">rk8938273@gmail.com</a></li>\r\n                    <li><i class=\"fa-solid fa-phone\"></i> : <a href=\"tel:+919876543210\"  target=\"_blank\">+91 9876543210</a></li>\r\n                    <li><i class=\"fa-brands fa-github\"></i> : <a href=\"https://github.com/Ravindra1807\"  target=\"_blank\">Ravindra1807</a>\r\n                    </li>\r\n                    <li><i class=\"fa-brands fa-linkedin\"></i> : <a\r\n                            href=\"https://www.linkedin.com/in/ravindra-kumar-a95761385\" target=\"_blank\">Ravindra Kumar</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n        </div>\r\n\r\n        <div class=\"footer-bottom\">\r\n            <p>© 2026 Tech Career Explorer. All Rights Reserved. | Developed by Ravindra Kumar</p>\r\n        </div>\r\n    </footer>\r\n\r\n    <script>\r\n        const menuBtn = document.querySelector(\".menu-btn\");\r\n        const navLinks = document.querySelector(\"#navLinks\");\r\n        const dropdowns = document.querySelectorAll(\".dropdown\");\r\n\r\n        // Mobile hamburger toggle\r\n        menuBtn.addEventListener(\"click\", (e) => {\r\n            e.stopPropagation();\r\n            navLinks.classList.toggle(\"active\");\r\n        });\r\n\r\n        // Close navbar + all dropdowns on outside click\r\n        document.addEventListener(\"click\", (e) => {\r\n            if (!navLinks.contains(e.target) && !menuBtn.contains(e.target)) {\r\n                navLinks.classList.remove(\"active\");\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n            }\r\n        });\r\n\r\n        // Dropdown toggle — 1 click open, same click close\r\n        dropdowns.forEach((dropdown) => {\r\n            const toggle = dropdown.querySelector(\".dropdown-toggle\");\r\n\r\n            toggle.addEventListener(\"click\", (e) => {\r\n                e.preventDefault();\r\n                e.stopPropagation();\r\n\r\n                const isOpen = dropdown.classList.contains(\"open\");\r\n\r\n                // close all first\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n\r\n                // toggle this one\r\n                if (!isOpen) dropdown.classList.add(\"open\");\r\n            });\r\n        });\r\n\r\n        // Clicks inside dropdown-menu don't close it\r\n        document.querySelectorAll(\".dropdown-menu\").forEach((menu) => {\r\n            menu.addEventListener(\"click\", (e) => e.stopPropagation());\r\n        });\r\n    </script>\r\n\r\n\r\n</body>\r\n\r\n</html>"
        }
    ]
