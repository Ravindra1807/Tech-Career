            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Space+Mono:wght@400&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\r\n    <link\r\n        href=\"https://fonts.googleapis.com/css2?family=Black+Ops+One&family=DM+Serif+Display:ital@0;1&family=Electrolize&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap\">\r\n    <title>UI/UX Design - TechCareer Explorer</title>\r\n   <link rel=\"stylesheet\" href=\"CSS/UI_UX.css\">\r\n</head>\r\n\r\n<body>\r\n\r\n    <!-- ============ HEADER ============ -->\r\n    <header>\r\n        <a class=\"head-icon\" href=\"#\">\r\n            <div class=\"image-icon\">\r\n                <img src=\"images/Icon.png\" alt=\"TechCareer Explorer logo\" height=\"60\" width=\"60\">\r\n            </div>\r\n            <span class=\"nav-left\">TechCareer·Explorer</span>\r\n        </a>\r\n\r\n        <button class=\"menu-btn\" aria-label=\"Toggle navigation menu\">\r\n            <i class=\"fa fa-cog\"></i>\r\n        </button>\r\n\r\n        <ul class=\"navbar\" id=\"navLinks\">\r\n            <li>\r\n                <a class=\"nav-one\" href=\"index.html\">\r\n                    <i class=\"fa-solid fa-house\"></i>\r\n                    Home\r\n                </a>\r\n            </li>\r\n\r\n            <li class=\"dropdown\">\r\n                <a href=\"#\" class=\"nav-other dropdown-toggle\">\r\n                    <i class=\"fa-solid fa-briefcase\"></i>\r\n                    Category Roles\r\n                    <i class=\"fa-solid fa-chevron-down\"></i>\r\n                </a>\r\n                <ul class=\"dropdown-menu\">\r\n                    <li><a href=\"web-development.html\">Web Developer</a></li>\r\n                    <li><a href=\"mobile-development.html\">Mobile Development</a></li>\r\n                    <li><a href=\"AIML.html\">AI & Machine Learning</a></li>\r\n                    <li><a href=\"data-Analytics.html\">Data & Analytics</a></li>\r\n                    <li><a href=\"UX_UX.html\">UI/UX Design</a></li>\r\n                    <li><a href=\"cyber.html\">Cybersecurity</a></li>\r\n                    <li><a href=\"cloud&DevOps.html\">Cloud & DevOps</a></li>\r\n                    <li><a href=\"game-de.html\">Game Development</a></li>\r\n                </ul>\r\n            </li>\r\n        </ul>\r\n    </header>\r\n\r\n    <!-- ============ HERO SECTION ============ -->\r\n    <div class=\"hero\">\r\n        <h1>UI/UX Design</h1>\r\n        <p>Create beautiful, user-centered digital experiences. Master UI Design, UX Research, Interaction Design, and\r\n            Product Design.</p>\r\n    </div>\r\n\r\n    <!-- ============ MAIN CONTAINER ============ -->\r\n    <div class=\"container\">\r\n\r\n        <!-- ============ CAREER PATHS ============ -->\r\n        <section id=\"careers\">\r\n            <h2>Choose Your Career Path</h2>\r\n            <div class=\"cards-container\">\r\n                <div class=\"card\">\r\n                    <h3>UI Designer</h3>\r\n                    <p>Design beautiful user interfaces and visual elements for digital products.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Figma</li>\r\n                        <li>Adobe XD</li>\r\n                        <li>Visual Design</li>\r\n                        <li>Prototyping</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>UX Designer</h3>\r\n                    <p>Create seamless user experiences through research, wireframing, and testing.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>User Research</li>\r\n                        <li>Wireframing</li>\r\n                        <li>Information Architecture</li>\r\n                        <li>Usability Testing</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Product Designer</h3>\r\n                    <p>Bridge design and product strategy to create comprehensive digital solutions.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Product Strategy</li>\r\n                        <li>UI/UX Design</li>\r\n                        <li>User Analytics</li>\r\n                        <li>Prototyping</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Interaction Designer</h3>\r\n                    <p>Design interactive experiences and animations that delight users.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Micro-interactions</li>\r\n                        <li>Animation</li>\r\n                        <li>Motion Design</li>\r\n                        <li>Prototyping</li>\r\n                    </ul>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ DETAILED ROLES ============ -->\r\n        <section>\r\n            <h2>UI Designer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You create the visual design of digital products. You work on layouts, typography, color schemes, and\r\n                    interactive elements that users see and interact with daily.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Figma / Adobe XD - Design tools</li>\r\n                    <li>Visual Design - Color theory, typography, spacing</li>\r\n                    <li>UI Patterns & Components - Design systems</li>\r\n                    <li>Prototyping - Creating interactive mockups</li>\r\n                    <li>CSS / Web basics - Understanding implementation</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹4 - 10 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Junior UI Designer</li>\r\n                    <li>Product UI Designer</li>\r\n                    <li>Visual Designer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>UX Designer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You research user needs and create solutions that solve real problems. You conduct user research,\r\n                    create wireframes, and test designs to ensure the best user experience.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>User Research - Interviews, surveys, analytics</li>\r\n                    <li>Wireframing - Sketching and digital wireframes</li>\r\n                    <li>Information Architecture - Organizing content logically</li>\r\n                    <li>Usability Testing - Testing with real users</li>\r\n                    <li>Problem Solving - Finding creative solutions</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹5 - 12 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>UX Designer</li>\r\n                    <li>UX Researcher</li>\r\n                    <li>Interaction Designer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Product Designer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You combine UX, UI, and product strategy to create complete digital solutions. You work across design\r\n                    and product teams to define strategy and execute designs.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Product Strategy - Understanding business goals</li>\r\n                    <li>UX & UI Design - Full spectrum design skills</li>\r\n                    <li>Data Analysis - Using metrics to guide decisions</li>\r\n                    <li>Communication - Presenting ideas to stakeholders</li>\r\n                    <li>Cross-functional collaboration - Working with engineers and PMs</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹8 - 18 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Product Designer</li>\r\n                    <li>Lead Designer</li>\r\n                    <li>Design Manager</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ SKILLS COMPARISON ============ -->\r\n        <section>\r\n            <h2>Skills Comparison Table</h2>\r\n            <div class=\"table-wrapper\">\r\n                <table>\r\n                    <thead>\r\n                        <tr>\r\n                            <th>Skills</th>\r\n                            <th>UI Designer</th>\r\n                            <th>UX Designer</th>\r\n                            <th>Product Designer</th>\r\n                            <th>Interaction Designer</th>\r\n                        </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                        <tr>\r\n                            <td>Visual Design</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Figma / Design Tools</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>User Research</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Wireframing</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Prototyping & Animation</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Usability Testing</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Product Strategy</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Communication & Presentation</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                    </tbody>\r\n                </table>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ ROADMAP ============ -->\r\n        <section id=\"roadmap\">\r\n            <h2>UI/UX Design Learning Roadmap</h2>\r\n            <div class=\"roadmap-list\">\r\n                <h3>Step-by-Step Learning Path</h3>\r\n                <ol>\r\n                    <li><strong>Month 1-2:</strong> Learn design fundamentals - color theory, typography, spacing</li>\r\n                    <li><strong>Month 2-3:</strong> Master Figma and design tools - layouts and components</li>\r\n                    <li><strong>Month 3-4:</strong> Study user experience basics - wireframing and user flows</li>\r\n                    <li><strong>Month 4-5:</strong> Learn user research - interviews, surveys, analytics</li>\r\n                    <li><strong>Month 5-6:</strong> Explore specialization - choose UI, UX, Product, or Interaction path\r\n                    </li>\r\n                    <li><strong>Month 6-7:</strong> Build portfolio projects - real case studies</li>\r\n                    <li><strong>Month 7+:</strong> Specialize and contribute - deep dive into your chosen area</li>\r\n                </ol>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ TECHNOLOGIES ============ -->\r\n        <section id=\"resources\">\r\n            <h2>Popular Design Tools & Technologies</h2>\r\n            <div class=\"tech-grid\">\r\n                <div class=\"tech-item\">Figma</div>\r\n                <div class=\"tech-item\">Adobe XD</div>\r\n                <div class=\"tech-item\">Sketch</div>\r\n                <div class=\"tech-item\">Protopie</div>\r\n                <div class=\"tech-item\">Framer</div>\r\n                <div class=\"tech-item\">Adobe Illustrator</div>\r\n                <div class=\"tech-item\">Adobe Photoshop</div>\r\n                <div class=\"tech-item\">After Effects</div>\r\n                <div class=\"tech-item\">InVision</div>\r\n                <div class=\"tech-item\">Principle</div>\r\n                <div class=\"tech-item\">Webflow</div>\r\n                <div class=\"tech-item\">Spline 3D</div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ PROJECT IDEAS ============ -->\r\n        <section>\r\n            <h2>Project Ideas to Practice</h2>\r\n            <div class=\"projects-grid\">\r\n                <div class=\"project-item\">Mobile App Redesign</div>\r\n                <div class=\"project-item\">E-Commerce Website</div>\r\n                <div class=\"project-item\">SaaS Dashboard</div>\r\n                <div class=\"project-item\">Travel App</div>\r\n                <div class=\"project-item\">Social Media Redesign</div>\r\n                <div class=\"project-item\">Finance App</div>\r\n                <div class=\"project-item\">Health & Fitness App</div>\r\n                <div class=\"project-item\">Job Portal</div>\r\n            </div>\r\n        </section>\r\n\r\n        <section class=\"resources\">\r\n            <h3>📚 Free Learning Resources</h3>\r\n            <ul>\r\n                <li><a href=\"https://www.nngroup.com/\" target=\"_blank\">Nielsen Norman Group</a></li>\r\n                <li><a href=\"https://www.interaction-design.org/\" target=\"_blank\">Interaction Design Foundation</a></li>\r\n                <li><a href=\"https://www.designerly.io/\" target=\"_blank\">Designerly</a></li>\r\n                <li><a href=\"https://www.invisionapp.com/inside-design\" target=\"_blank\">InVision Design Blog</a></li>\r\n                <li><a href=\"https://dribbble.com/\" target=\"_blank\">Dribbble</a></li>\r\n            </ul>\r\n\r\n            <h3>🎥 Free Video Tutorials</h3>\r\n            <ul>\r\n                <li><a href=\"https://www.youtube.com/@FigmaDesign\" target=\"_blank\">Figma Design Official</a></li>\r\n                <li><a href=\"https://www.youtube.com/@DavidArty\" target=\"_blank\">David Arty Design</a></li>\r\n                <li><a href=\"https://www.youtube.com/@AlejandroAO\" target=\"_blank\">Alejandro AO</a></li>\r\n                <li><a href=\"https://www.youtube.com/@DesignCourse\" target=\"_blank\">Design Course</a></li>\r\n                <li><a href=\"https://www.youtube.com/@CharliMarietell\" target=\"_blank\">Charli Marietell</a></li>\r\n            </ul>\r\n        </section>\r\n\r\n        <!-- ============ FAQ ============ -->\r\n        <section id=\"faq\">\r\n            <h2>Frequently Asked Questions</h2>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What is the difference between UI and UX Design?</h4>\r\n                <p>UI Designer focuses on how the product looks and feels - colors, typography, buttons, layouts. UX\r\n                    Designer focuses on how the product works - user research, flows, interactions, solving user\r\n                    problems.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What skills do I need to start UI/UX Design?</h4>\r\n                <p>Basic skills: creativity, communication, problem-solving. Technical skills: Figma, wireframing,\r\n                    prototyping. Soft skills: empathy, attention to detail, collaboration, and listening to feedback.\r\n                </p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Do I need coding skills to become a UX/UI Designer?</h4>\r\n                <p>Not required, but helpful. Understanding HTML/CSS basics helps you design more realistically and\r\n                    communicate better with developers. It's not essential to start your career.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What should I include in my UI/UX Design portfolio?</h4>\r\n                <p>Include 3-5 case studies showing your process. Each case study should have: problem statement,\r\n                    research insights, wireframes, prototypes, and results. Show your design thinking, not just final\r\n                    designs.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>How long does it take to learn UI/UX Design?</h4>\r\n                <p>You can learn basics in 2-3 months. Becoming job-ready typically takes 4-6 months with consistent\r\n                    practice. Mastery and specialization takes 1-2 years of real experience.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What's the average salary of a UI/UX Designer in India?</h4>\r\n                <p>Fresher designers earn ₹2-5 LPA. Mid-level designers earn ₹8-15 LPA. Senior designers earn ₹15-25+\r\n                    LPA. Salary depends on skills, experience, location, and company size.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Is UI/UX Design a good career choice?</h4>\r\n                <p>Yes! Demand is growing, salaries are competitive, remote opportunities are abundant, and the field\r\n                    offers creative fulfillment. It's perfect if you enjoy problem-solving and creating beautiful\r\n                    digital experiences.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Should I specialize in UI, UX, Product, or Interaction Design?</h4>\r\n                <p>Start by learning all areas. Then specialize based on your interests: UI if you love visual design,\r\n                    UX if you love research, Product if you like strategy, Interaction if you love motion and\r\n                    animations.</p>\r\n            </div>\r\n        </section>\r\n\r\n    </div>\r\n\r\n    <!-- ============ FOOTER ============ -->\r\n    <footer class=\"footer\">\r\n        <div class=\"footer-container\">\r\n            <div class=\"footer-box\">\r\n                <div class=\"U\">\r\n                    <h2>Tech Career</h2>\r\n                    <p>Discover technology careers, explore learning paths, and build your future in the tech industry.\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Quick Links</h3>\r\n                <ul>\r\n                    <li><a href=\"index.html\">➤ Home</a></li>\r\n                    <li><a href=\"index.html\">➤ Careers</a></li>\r\n                    <li><a href=\"index.html\">➤ Roadmaps</a></li>\r\n                    <li><a href=\"index.html\">➤ Resources</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Specializations</h3>\r\n                <ul>\r\n                    <li><a href=\"web-development.html\">➤ Web Development</a></li>\r\n                    <li><a href=\"mobile-development.html\">➤ Mobile Development</a></li>\r\n                    <li><a href=\"AIML.html\">➤ AI & ML</a></li>\r\n                    <li><a href=\"data-Analytics.html\">➤ Data & Analytics</a></li>\r\n                    <li><a href=\"UX_UX.html\">➤ UI/UX Design</a></li>\r\n                    <li><a href=\"cyber.html\">➤ Cybersecurity</a></li>\r\n                    <li><a href=\"cloud&DevOps.html\">➤ Cloud & DevOps</a></li>\r\n                    <li><a href=\"game-de.html\">➤ Game Development</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n           <div class=\"footer-box\">\r\n                <h3>Contact</h3>\r\n                <ul>\r\n                    <li><i class=\"fa-solid fa-envelope\"></i> : <a\r\n                            href=\"mailto:rk8938273@gmail.com\" target=\"_blank\">rk8938273@gmail.com</a></li>\r\n                    <li><i class=\"fa-solid fa-phone\"></i> : <a href=\"tel:+919876543210\"  target=\"_blank\">+91 9876543210</a></li>\r\n                    <li><i class=\"fa-brands fa-github\"></i> : <a href=\"https://github.com/Ravindra1807\"  target=\"_blank\">Ravindra1807</a>\r\n                    </li>\r\n                    <li><i class=\"fa-brands fa-linkedin\"></i> : <a\r\n                            href=\"https://www.linkedin.com/in/ravindra-kumar-a95761385\" target=\"_blank\">Ravindra Kumar</a></li>\r\n                </ul>\r\n            </div>\r\n        </div>\r\n\r\n        <div class=\"footer-bottom\">\r\n            <p>© 2026 Tech Career Explorer. All Rights Reserved. | Developed by Ravindra Kumar</p>\r\n        </div>\r\n    </footer>\r\n\r\n    <script>\r\n        const menuBtn = document.querySelector(\".menu-btn\");\r\n        const navLinks = document.querySelector(\"#navLinks\");\r\n        const dropdowns = document.querySelectorAll(\".dropdown\");\r\n\r\n        // Mobile hamburger toggle\r\n        menuBtn.addEventListener(\"click\", (e) => {\r\n            e.stopPropagation();\r\n            navLinks.classList.toggle(\"active\");\r\n        });\r\n\r\n        // Close navbar + all dropdowns on outside click\r\n        document.addEventListener(\"click\", (e) => {\r\n            if (!navLinks.contains(e.target) && !menuBtn.contains(e.target)) {\r\n                navLinks.classList.remove(\"active\");\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n            }\r\n        });\r\n\r\n        // Dropdown toggle — 1 click open, same click close\r\n        dropdowns.forEach((dropdown) => {\r\n            const toggle = dropdown.querySelector(\".dropdown-toggle\");\r\n\r\n            toggle.addEventListener(\"click\", (e) => {\r\n                e.preventDefault();\r\n                e.stopPropagation();\r\n\r\n                const isOpen = dropdown.classList.contains(\"open\");\r\n\r\n                // close all first\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n\r\n                // toggle this one\r\n                if (!isOpen) dropdown.classList.add(\"open\");\r\n            });\r\n        });\r\n\r\n        // Clicks inside dropdown-menu don't close it\r\n        document.querySelectorAll(\".dropdown-menu\").forEach((menu) => {\r\n            menu.addEventListener(\"click\", (e) => e.stopPropagation());\r\n        });\r\n    </script>\r\n\r\n</body>\r\n\r\n</html>"
        }
    ]
}