            "date": 1783652872512,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Space+Mono:wght@400&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\r\n    <title>TechCareer Explorer - AI & ML</title>\r\n   <link rel=\"stylesheet\" href=\"CSS/AIML.css\">\r\n</head>\r\n\r\n<body>\r\n\r\n    <header>\r\n\r\n        <a class=\"head-icon\" href=\"#\">\r\n            <div class=\"image-icon\">\r\n                <img src=\"images/Icon.png\" alt=\"TechCareer Explorer logo\" height=\"60\" width=\"60\">\r\n            </div>\r\n            <span class=\"nav-left\">TechCareer·Explorer</span>\r\n        </a>\r\n\r\n        <button class=\"menu-btn\" aria-label=\"Toggle navigation menu\">\r\n            <i class=\"fa fa-cog\"></i>\r\n        </button>\r\n\r\n        <ul class=\"navbar\" id=\"navLinks\">\r\n\r\n            <li>\r\n                <a class=\"nav-one\" href=\"index.html\">\r\n                    <i class=\"fa-solid fa-house\"></i>\r\n                    Home\r\n                </a>\r\n            </li>\r\n\r\n            <li class=\"dropdown\">\r\n                <a href=\"#\" class=\"nav-other dropdown-toggle\">\r\n                    <i class=\"fa-solid fa-briefcase\"></i>\r\n                    Category Roles\r\n                    <i class=\"fa-solid fa-chevron-down\"></i>\r\n                </a>\r\n                <ul class=\"dropdown-menu\">\r\n                    <li> <a href=\"web-development.html\">Web Developer </a></li>\r\n\r\n                    <li> <a href=\"mobile-development.html\"> Mobile Development</a></li>\r\n\r\n                    <li> <a href=\"AIML.html\">AI & Machine Learning</a></li>\r\n\r\n                    <li> <a href=\"data-Analytics.html\">Data & Analytics</a></li>\r\n\r\n                    <li> <a href=\"UX_UX.html\">UI/UX Design</a></li>\r\n\r\n                    <li> <a href=\"cyber.html\">Cybersecurity</a></li>\r\n\r\n                    <li> <a href=\"cloud&DevOps.html\">Cloud & DevOps</a></li>\r\n\r\n                    <li> <a href=\"game-de.html\">Game Development</a></li>\r\n\r\n                </ul>\r\n            </li>\r\n\r\n\r\n        </ul>\r\n\r\n\r\n\r\n    </header>\r\n    <!-- ============ HERO SECTION ============ -->\r\n    <div class=\"hero\">\r\n        <h1>Artificial Intelligence & Machine Learning</h1>\r\n        <p>Build intelligent systems and machine learning models that power the future. From AI Engineers to Data\r\n            Scientists.</p>\r\n    </div>\r\n\r\n\r\n    <!-- ============ MAIN CONTAINER ============ -->\r\n    <div class=\"container\">\r\n\r\n        <!-- ============ CAREER PATHS ============ -->\r\n        <section id=\"careers\">\r\n            <h2>Choose Your AI & ML Career Path</h2>\r\n            <div class=\"cards-container\">\r\n                <div class=\"card\">\r\n                    <h3>AI Engineer</h3>\r\n                    <p>Build intelligent systems and AI applications using deep learning and neural networks.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Python</li>\r\n                        <li>TensorFlow</li>\r\n                        <li>PyTorch</li>\r\n                        <li>Deep Learning</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>ML Engineer</h3>\r\n                    <p>Create machine learning models that solve real-world problems.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Python</li>\r\n                        <li>Scikit-learn</li>\r\n                        <li>SQL</li>\r\n                        <li>Feature Engineering</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Data Engineer</h3>\r\n                    <p>Design and maintain data pipelines that power AI and ML systems.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Python/Java</li>\r\n                        <li>SQL</li>\r\n                        <li>Spark</li>\r\n                        <li>Data Pipelines</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Prompt Engineer</h3>\r\n                    <p>Optimize prompts for LLMs and build AI-powered applications.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>LLMs (GPT, Claude)</li>\r\n                        <li>Prompt Design</li>\r\n                        <li>API Integration</li>\r\n                        <li>Python</li>\r\n                    </ul>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ DETAILED ROLES ============ -->\r\n        <section>\r\n            <h2>AI Engineer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You design and implement AI systems using advanced algorithms. You work on computer vision, NLP,\r\n                    robotics, and other cutting-edge AI applications.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Python - Primary programming language</li>\r\n                    <li>Deep Learning - TensorFlow, PyTorch, Keras</li>\r\n                    <li>Mathematics - Linear algebra, calculus, probability</li>\r\n                    <li>Neural Networks - CNNs, RNNs, Transformers</li>\r\n                    <li>Computer Vision - Image processing, object detection</li>\r\n                    <li>NLP - Natural Language Processing techniques</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹8 - 25 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>AI Engineer</li>\r\n                    <li>Deep Learning Engineer</li>\r\n                    <li>ML Researcher</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>ML Engineer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You build machine learning models for production. You handle data preprocessing, model training,\r\n                    evaluation, and deployment of ML solutions.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Python - Programming with ML libraries</li>\r\n                    <li>Data Analysis - Pandas, NumPy</li>\r\n                    <li>ML Algorithms - Regression, classification, clustering</li>\r\n                    <li>Feature Engineering - Data preprocessing</li>\r\n                    <li>Model Evaluation - Cross-validation, metrics</li>\r\n                    <li>SQL - Data querying</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹7 - 20 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Machine Learning Engineer</li>\r\n                    <li>ML Scientist</li>\r\n                    <li>Analytics Engineer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n\r\n        <section>\r\n            <h2>Data Engineer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You build data infrastructure and pipelines. You ensure data quality, availability, and accessibility\r\n                    for analytics and ML teams.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Python/Java - Programming languages</li>\r\n                    <li>SQL - Database queries</li>\r\n                    <li>Big Data - Spark, Hadoop, Kafka</li>\r\n                    <li>Databases - SQL, NoSQL, Data Warehouses</li>\r\n                    <li>ETL - Data pipelines and workflows</li>\r\n                    <li>Cloud Platforms - AWS, GCP, Azure</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹7 - 22 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Data Engineer</li>\r\n                    <li>Pipeline Engineer</li>\r\n                    <li>Infrastructure Engineer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Prompt Engineer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You optimize prompts for Large Language Models and build AI-powered applications. You work with\r\n                    ChatGPT, Claude, Gemini and other LLMs.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>LLMs Understanding - How they work</li>\r\n                    <li>Prompt Design - Effective prompt engineering</li>\r\n                    <li>Python - LLM API integration</li>\r\n                    <li>OpenAI/Anthropic APIs - Working with LLMs</li>\r\n                    <li>RAG - Retrieval Augmented Generation</li>\r\n                    <li>Problem Solving - Creative solutions</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹6 - 18 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Prompt Engineer</li>\r\n                    <li>AI Application Developer</li>\r\n                    <li>LLM Specialist</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ SKILLS COMPARISON ============ -->\r\n\r\n        <!-- ============ SKILLS COMPARISON ============ -->\r\n        <section>\r\n            <h2>Skills Comparison Table</h2>\r\n            <div class=\"table-wrapper\">\r\n                <table>\r\n                    <thead>\r\n                        <tr>\r\n                            <th>Skills</th>\r\n                            <th>AI Engineer</th>\r\n                            <th>ML Engineer</th>\r\n                            <th>Data Engineer</th>\r\n                            <th>Prompt Engineer</th>\r\n                        </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                        <tr>\r\n                            <td>Python</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Mathematics</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Deep Learning</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>SQL</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Big Data (Spark)</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Feature Engineering</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>LLMs & APIs</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Cloud Platforms</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                    </tbody>\r\n                </table>\r\n            </div>\r\n        </section>\r\n\r\n\r\n\r\n\r\n\r\n        <!-- ============ ROADMAP ============ -->\r\n        <section id=\"roadmap\">\r\n            <h2>AI & ML Learning Roadmap</h2>\r\n            <div class=\"roadmap-list\">\r\n                <h3>Step-by-Step Learning Path</h3>\r\n                <ol>\r\n                    <li><strong>Month 1-2:</strong> Python programming - basics to advanced concepts</li>\r\n                    <li><strong>Month 2-3:</strong> Mathematics - linear algebra, calculus, probability, statistics</li>\r\n                    <li><strong>Month 3-4:</strong> Data manipulation - NumPy, Pandas, data cleaning</li>\r\n                    <li><strong>Month 4-5:</strong> Machine Learning basics - algorithms, training, evaluation</li>\r\n                    <li><strong>Month 5-6:</strong> Deep Learning - neural networks, TensorFlow/PyTorch</li>\r\n                    <li><strong>Month 6-7:</strong> Specialization - choose AI/ML/Data/Prompt engineering path</li>\r\n                    <li><strong>Month 7-9:</strong> Advanced topics - specific to your path</li>\r\n                    <li><strong>Month 9-10:</strong> Build real projects - portfolio building</li>\r\n                    <li><strong>Month 10+:</strong> Deploy & optimize - production-ready solutions</li>\r\n                </ol>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ TECHNOLOGIES ============ -->\r\n        <section id=\"resources\">\r\n            <h2>Popular Technologies</h2>\r\n            <div class=\"tech-grid\">\r\n                <div class=\"tech-item\">Python</div>\r\n                <div class=\"tech-item\">TensorFlow</div>\r\n                <div class=\"tech-item\">PyTorch</div>\r\n                <div class=\"tech-item\">Scikit-learn</div>\r\n                <div class=\"tech-item\">Pandas</div>\r\n                <div class=\"tech-item\">NumPy</div>\r\n                <div class=\"tech-item\">SQL</div>\r\n                <div class=\"tech-item\">Spark</div>\r\n                <div class=\"tech-item\">Kafka</div>\r\n                <div class=\"tech-item\">OpenAI API</div>\r\n                <div class=\"tech-item\">Hugging Face</div>\r\n                <div class=\"tech-item\">AWS/GCP</div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ PROJECT IDEAS ============ -->\r\n        <section>\r\n            <h2>Project Ideas to Practice</h2>\r\n            <div class=\"projects-grid\">\r\n                <div class=\"project-item\">Iris Flower Classification</div>\r\n                <div class=\"project-item\">House Price Prediction</div>\r\n                <div class=\"project-item\">Digit Recognition (MNIST)</div>\r\n                <div class=\"project-item\">Sentiment Analysis</div>\r\n                <div class=\"project-item\">Chatbot with LLM</div>\r\n                <div class=\"project-item\">Image Classification</div>\r\n                <div class=\"project-item\">Recommendation System</div>\r\n                <div class=\"project-item\">Time Series Forecasting</div>\r\n            </div>\r\n        </section>\r\n\r\n\r\n\r\n        <section class=\"resources\">\r\n\r\n            <h3>📚 Free Learning Resources</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://www.coursera.org/learn/machine-learning\" target=\"_blank\">Machine Learning\r\n                        Course</a></li>\r\n\r\n                <li><a href=\"https://developers.google.com/machine-learning\" target=\"_blank\">Google ML Guides</a></li>\r\n\r\n                <li><a href=\"https://www.kaggle.com/learn\" target=\"_blank\">Kaggle Learn</a></li>\r\n\r\n                <li><a href=\"https://roadmap.sh/ai-data-scientist\" target=\"_blank\">AI & Data Scientist Roadmap</a></li>\r\n\r\n                <li><a href=\"https://www.geeksforgeeks.org/machine-learning/\" target=\"_blank\">GeeksforGeeks Machine\r\n                        Learning</a></li>\r\n            </ul>\r\n\r\n            <h3>🎥 Free Video Tutorials</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://www.youtube.com/@freecodecamp\" target=\"_blank\">freeCodeCamp</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@KrishNaik06\" target=\"_blank\">Krish Naik</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@campusx-official\" target=\"_blank\">CampusX</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@Codebasics\" target=\"_blank\">Codebasics</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@GoogleDevelopers\" target=\"_blank\">Google Developers</a></li>\r\n            </ul>\r\n\r\n        </section>\r\n\r\n        <!-- ============ FAQ ============ -->\r\n        <section id=\"faq\">\r\n            <h2>Frequently Asked Questions</h2>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What's the difference between AI Engineer and ML Engineer?</h4>\r\n                <p>AI Engineers build broader intelligent systems (computer vision, NLP, robotics). ML Engineers focus\r\n                    on building and optimizing machine learning models. AI requires more deep learning, ML focuses on\r\n                    algorithms and production.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What does a Data Engineer do?</h4>\r\n                <p>Data Engineers build data infrastructure and pipelines. They ensure data quality, availability, and\r\n                    processing at scale. They work with databases, big data tools, and ETL processes.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What is Prompt Engineering?</h4>\r\n                <p>Prompt Engineering is the art of crafting prompts for Large Language Models like ChatGPT and Claude.\r\n                    You optimize prompts to get better outputs and build LLM-powered applications.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Which path is easiest to start?</h4>\r\n                <p>Prompt Engineering is the easiest to start - you need just Python basics. ML Engineer is next. Data\r\n                    Engineer and AI Engineer are harder as they require more math and deep learning knowledge.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>How long does it take to learn AI/ML?</h4>\r\n                <p>Basics: 3-4 months. Intermediate: 6-8 months. Advanced/Production-ready: 1-2 years. It depends on\r\n                    your background and daily practice.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Do I need a CS degree for AI/ML jobs?</h4>\r\n                <p>No. Many successful AI/ML engineers are self-taught. What matters is your skills, portfolio, and\r\n                    practical projects. Build a strong GitHub portfolio to showcase your work.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What's the highest salary in AI/ML?</h4>\r\n                <p>Senior AI Engineers and ML researchers can earn ₹20-50+ LPA. With experience and expertise, you can\r\n                    get even higher compensation in top tech companies.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What should I learn first - ML or Data Engineering?</h4>\r\n                <p>Learn Machine Learning first - it's more foundational. Then learn Data Engineering if interested. Or\r\n                    start with Prompt Engineering if you want to enter AI quickly.</p>\r\n            </div>\r\n        </section>\r\n\r\n    </div>\r\n\r\n    <!-- ============ FOOTER ============ -->\r\n    <footer class=\"footer\">\r\n        <div class=\"footer-container\">\r\n\r\n            <div class=\"footer-box\">\r\n                <div class=\"U\">\r\n                    <h2>Tech Career</h2>\r\n                    <p>\r\n                        Discover technology careers, explore learning paths,\r\n                        and build your future in the tech industry.\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Quick Links</h3>\r\n                <ul>\r\n                    <li><a href=\"index.html\">➤ Home</a></li>\r\n                    <li><a href=\"index.html\">➤ Careers</a></li>\r\n                    <li><a href=\"index.html\">➤ Roadmaps</a></li>\r\n                    <li><a href=\"index.html\">➤ Resources</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Specializations</h3>\r\n                <ul>\r\n                    <li><a href=\"web-development.html\">➤ Web Development</a></li>\r\n                    <li><a href=\"mobile-development.html\">➤ Mobile Development</a></li>\r\n                    <li><a href=\"AIML.html\">➤ AI & ML</a></li>\r\n                    <li><a href=\"data-Analytics.html\">➤ Data & Analytics</a></li>\r\n                    <li><a href=\"UX_UX.html\">➤ UI/UX Design</a></li>\r\n                    <li><a href=\"cyber.html\">➤ Cybersecurity</a></li>\r\n                    <li><a href=\"cloud&DevOps.html\">➤ Cloud & DevOps</a></li>\r\n                    <li><a href=\"game-de.html\">➤ Game Development</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n          <div class=\"footer-box\">\r\n                <h3>Contact</h3>\r\n                <ul>\r\n                    <li><i class=\"fa-solid fa-envelope\"></i> : <a\r\n                            href=\"mailto:rk8938273@gmail.com\" target=\"_blank\">rk8938273@gmail.com</a></li>\r\n                    <li><i class=\"fa-solid fa-phone\"></i> : <a href=\"tel:+919876543210\"  target=\"_blank\">+91 9876543210</a></li>\r\n                    <li><i class=\"fa-brands fa-github\"></i> : <a href=\"https://github.com/Ravindra1807\"  target=\"_blank\">Ravindra1807</a>\r\n                    </li>\r\n                    <li><i class=\"fa-brands fa-linkedin\"></i> : <a\r\n                            href=\"https://www.linkedin.com/in/ravindra-kumar-a95761385\" target=\"_blank\">Ravindra Kumar</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n        </div>\r\n\r\n        <div class=\"footer-bottom\">\r\n            <p>© 2026 Tech Career Explorer. All Rights Reserved. | Developed by Ravindra Kumar</p>\r\n        </div>\r\n    </footer>\r\n\r\n    <script>\r\n        const menuBtn = document.querySelector(\".menu-btn\");\r\n        const navLinks = document.querySelector(\"#navLinks\");\r\n        const dropdowns = document.querySelectorAll(\".dropdown\");\r\n\r\n        // Mobile hamburger toggle\r\n        menuBtn.addEventListener(\"click\", (e) => {\r\n            e.stopPropagation();\r\n            navLinks.classList.toggle(\"active\");\r\n        });\r\n\r\n        // Close navbar + all dropdowns on outside click\r\n        document.addEventListener(\"click\", (e) => {\r\n            if (!navLinks.contains(e.target) && !menuBtn.contains(e.target)) {\r\n                navLinks.classList.remove(\"active\");\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n            }\r\n        });\r\n\r\n        // Dropdown toggle — 1 click open, same click close\r\n        dropdowns.forEach((dropdown) => {\r\n            const toggle = dropdown.querySelector(\".dropdown-toggle\");\r\n\r\n            toggle.addEventListener(\"click\", (e) => {\r\n                e.preventDefault();\r\n                e.stopPropagation();\r\n\r\n                const isOpen = dropdown.classList.contains(\"open\");\r\n\r\n                // close all first\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n\r\n                // toggle this one\r\n                if (!isOpen) dropdown.classList.add(\"open\");\r\n            });\r\n        });\r\n\r\n        // Clicks inside dropdown-menu don't close it\r\n        document.querySelectorAll(\".dropdown-menu\").forEach((menu) => {\r\n            menu.addEventListener(\"click\", (e) => e.stopPropagation());\r\n        });\r\n    </script>\r\n\r\n</body>\r\n\r\n</html>"
