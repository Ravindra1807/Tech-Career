            "date": 1783652881480,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Space+Mono:wght@400&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\r\n    <link\r\n        href=\"https://fonts.googleapis.com/css2?family=Black+Ops+One&family=DM+Serif+Display:ital@0;1&family=Electrolize&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap\">\r\n    <title>Game Development - TechCareer Explorer</title>\r\n    <link rel=\"stylesheet\" href=\"CSS/game-dev.css\">\r\n</head>\r\n\r\n<body>\r\n\r\n    <!-- ============ HEADER ============ -->\r\n    <header>\r\n        <a class=\"head-icon\" href=\"#\">\r\n            <div class=\"image-icon\">\r\n                <img src=\"images/Icon.png\" alt=\"TechCareer Explorer logo\" height=\"60\" width=\"60\">\r\n            </div>\r\n            <span class=\"nav-left\">TechCareer·Explorer</span>\r\n        </a>\r\n\r\n        <button class=\"menu-btn\" aria-label=\"Toggle navigation menu\">\r\n            <i class=\"fa fa-cog\"></i>\r\n        </button>\r\n\r\n        <ul class=\"navbar\" id=\"navLinks\">\r\n            <li>\r\n                <a class=\"nav-one\" href=\"index.html\">\r\n                    <i class=\"fa-solid fa-house\"></i>\r\n                    Home\r\n                </a>\r\n            </li>\r\n\r\n            <li class=\"dropdown\">\r\n                <a href=\"#\" class=\"nav-other dropdown-toggle\">\r\n                    <i class=\"fa-solid fa-briefcase\"></i>\r\n                    Category Roles\r\n                    <i class=\"fa-solid fa-chevron-down\"></i>\r\n                </a>\r\n                <ul class=\"dropdown-menu\">\r\n                    <li><a href=\"web-development.html\">Web Developer</a></li>\r\n                    <li><a href=\"mobile-development.html\">Mobile Development</a></li>\r\n                    <li><a href=\"AIML.html\">AI & Machine Learning</a></li>\r\n                    <li><a href=\"data-Analytics.html\">Data & Analytics</a></li>\r\n                    <li><a href=\"UX_UX.html\">UI/UX Design</a></li>\r\n                    <li><a href=\"cyber.html\">Cybersecurity</a></li>\r\n                    <li><a href=\"cloud&DevOps.html\">Cloud & DevOps</a></li>\r\n                    <li><a href=\"game-de.html\">Game Development</a></li>\r\n                </ul>\r\n            </li>\r\n        </ul>\r\n    </header>\r\n\r\n    <!-- ============ HERO SECTION ============ -->\r\n    <div class=\"hero\">\r\n        <h1>Game Development</h1>\r\n        <p>Create immersive gaming experiences. Master game engines, design, programming, and bring your creative vision\r\n            to life.</p>\r\n    </div>\r\n\r\n    <!-- ============ MAIN CONTAINER ============ -->\r\n    <div class=\"container\">\r\n\r\n        <!-- ============ CAREER PATHS ============ -->\r\n        <section id=\"careers\">\r\n            <h2>Choose Your Game Development Path</h2>\r\n            <div class=\"cards-container\">\r\n                <div class=\"card\">\r\n                    <h3>Game Developer</h3>\r\n                    <p>Develop complete games using game engines and programming languages.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>C#/C++</li>\r\n                        <li>Game Engines</li>\r\n                        <li>Physics & AI</li>\r\n                        <li>Networking</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Game Designer</h3>\r\n                    <p>Design game mechanics, levels, and create engaging user experiences.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Level Design</li>\r\n                        <li>Game Mechanics</li>\r\n                        <li>Prototyping</li>\r\n                        <li>Player Psychology</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Unity Developer</h3>\r\n                    <p>Specialize in Unity engine to create 2D/3D games for multiple platforms.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Unity Engine</li>\r\n                        <li>C# Programming</li>\r\n                        <li>Asset Management</li>\r\n                        <li>Mobile/Web Build</li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h3>Unreal Engine Developer</h3>\r\n                    <p>Build AAA-quality games using Unreal Engine and advanced graphics.</p>\r\n                    <ul class=\"tech-list\">\r\n                        <li>Unreal Engine</li>\r\n                        <li>C++ Programming</li>\r\n                        <li>Blueprint Visual Scripting</li>\r\n                        <li>Advanced Graphics</li>\r\n                    </ul>\r\n                </div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ DETAILED ROLES ============ -->\r\n        <section>\r\n            <h2>Game Developer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You write code and develop game systems. You implement game mechanics, handle physics, AI,\r\n                    networking, and optimize performance across platforms.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>C# or C++ - Primary programming languages</li>\r\n                    <li>Game Engines - Unity or Unreal Engine</li>\r\n                    <li>Physics & Math - Vectors, trigonometry, collision</li>\r\n                    <li>AI & Pathfinding - Creating intelligent NPCs</li>\r\n                    <li>Networking - Multiplayer game systems</li>\r\n                    <li>Debugging & Optimization - Performance tuning</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹5 - 16 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Junior Game Developer</li>\r\n                    <li>Gameplay Programmer</li>\r\n                    <li>Graphics Programmer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Game Designer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You create the vision and gameplay experience. You design levels, mechanics, systems, and create game\r\n                    design documents that guide development.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Level Design - Creating engaging environments</li>\r\n                    <li>Game Mechanics - Designing core gameplay systems</li>\r\n                    <li>Prototyping - Testing ideas quickly</li>\r\n                    <li>Player Psychology - Understanding player behavior</li>\r\n                    <li>Documentation - Detailed design documents</li>\r\n                    <li>Balancing - Game economy and difficulty</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹6 - 15 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Level Designer</li>\r\n                    <li>Systems Designer</li>\r\n                    <li>Lead Designer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Unity Developer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You specialize in Unity engine to create games for PC, Mobile, Web, and Consoles. You use C# and\r\n                    Unity tools to build complete games.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Unity Engine - Complete mastery</li>\r\n                    <li>C# Programming - Object-oriented design</li>\r\n                    <li>UI/UX - User interface creation</li>\r\n                    <li>Asset Management - Importing and organizing</li>\r\n                    <li>Scripting - Game logic and behavior</li>\r\n                    <li>Building & Deployment - Platform-specific builds</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹5 - 14 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Unity Developer</li>\r\n                    <li>Mobile Game Developer (Unity)</li>\r\n                    <li>Indie Game Developer</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <section>\r\n            <h2>Unreal Engine Developer Details</h2>\r\n            <div class=\"role-info\">\r\n                <h4>What You'll Do</h4>\r\n                <p>You develop high-quality AAA games using Unreal Engine. You leverage advanced graphics, C++, and\r\n                    Blueprint systems to create cutting-edge experiences.</p>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Skills Required</h4>\r\n                <ul>\r\n                    <li>Unreal Engine - Advanced features</li>\r\n                    <li>C++ Programming - Performance optimization</li>\r\n                    <li>Blueprint Visual Scripting - Rapid development</li>\r\n                    <li>Graphics Programming - Shaders, materials</li>\r\n                    <li>Advanced AI - Behavior trees, planning</li>\r\n                    <li>Console Development - PS5, Xbox Series X</li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"salary-box\">\r\n                <div class=\"label\">Average Salary (India)</div>\r\n                <div class=\"amount\">₹8 - 20 LPA</div>\r\n            </div>\r\n\r\n            <div class=\"role-info\">\r\n                <h4>Top Job Roles</h4>\r\n                <ul>\r\n                    <li>Unreal Engine Developer</li>\r\n                    <li>Senior Gameplay Programmer</li>\r\n                    <li>Tech Lead</li>\r\n                </ul>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ SKILLS COMPARISON ============ -->\r\n        <section>\r\n            <h2>Skills Comparison Table</h2>\r\n            <div class=\"table-wrapper\">\r\n                <table>\r\n                    <thead>\r\n                        <tr>\r\n                            <th>Skills</th>\r\n                            <th>Game Developer</th>\r\n                            <th>Game Designer</th>\r\n                            <th>Unity Developer</th>\r\n                            <th>Unreal Developer</th>\r\n                        </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                        <tr>\r\n                            <td>Programming (C#/C++)</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Game Engine Mastery</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Level Design</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Physics & AI</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Game Design & Mechanics</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Graphics Programming</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>Networking & Multiplayer</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"cross\">✗</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                        <tr>\r\n                            <td>UI/UX Design</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                            <td class=\"checkmark\">✓</td>\r\n                        </tr>\r\n                    </tbody>\r\n                </table>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ ROADMAP ============ -->\r\n        <section id=\"roadmap\">\r\n            <h2>Game Development Learning Roadmap</h2>\r\n            <div class=\"roadmap-list\">\r\n                <h3>Step-by-Step Learning Path</h3>\r\n                <ol>\r\n                    <li><strong>Month 1-2:</strong> Programming basics - C# or C++ fundamentals</li>\r\n                    <li><strong>Month 2-3:</strong> Game development concepts - physics, vectors, collision detection\r\n                    </li>\r\n                    <li><strong>Month 3-4:</strong> Choose engine - Unity or Unreal Engine fundamentals</li>\r\n                    <li><strong>Month 4-5:</strong> Game mechanics - scripting, input handling, game loops</li>\r\n                    <li><strong>Month 5-6:</strong> Level design - creating engaging environments</li>\r\n                    <li><strong>Month 6-7:</strong> Graphics & Audio - shaders, particle effects, sound design</li>\r\n                    <li><strong>Month 7-8:</strong> Networking - multiplayer basics</li>\r\n                    <li><strong>Month 8-10:</strong> Build portfolio games - showcase your skills</li>\r\n                    <li><strong>Month 10+:</strong> Specialize - VR, mobile, AAA console games</li>\r\n                </ol>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ TECHNOLOGIES ============ -->\r\n        <section id=\"resources\">\r\n            <h2>Popular Game Development Tools</h2>\r\n            <div class=\"tech-grid\">\r\n                <div class=\"tech-item\">Unity</div>\r\n                <div class=\"tech-item\">Unreal Engine</div>\r\n                <div class=\"tech-item\">Godot</div>\r\n                <div class=\"tech-item\">C#</div>\r\n                <div class=\"tech-item\">C++</div>\r\n                <div class=\"tech-item\">Python</div>\r\n                <div class=\"tech-item\">Blender</div>\r\n                <div class=\"tech-item\">Maya</div>\r\n                <div class=\"tech-item\">Photoshop</div>\r\n                <div class=\"tech-item\">Wwise</div>\r\n                <div class=\"tech-item\">FMOD</div>\r\n                <div class=\"tech-item\">Git</div>\r\n            </div>\r\n        </section>\r\n\r\n        <!-- ============ PROJECT IDEAS ============ -->\r\n        <section>\r\n            <h2>Project Ideas to Practice</h2>\r\n            <div class=\"projects-grid\">\r\n                <div class=\"project-item\">2D Platformer</div>\r\n                <div class=\"project-item\">3D Shooter</div>\r\n                <div class=\"project-item\">Puzzle Game</div>\r\n                <div class=\"project-item\">RPG Demo</div>\r\n                <div class=\"project-item\">Racing Game</div>\r\n                <div class=\"project-item\">Tower Defense</div>\r\n                <div class=\"project-item\">VR Experience</div>\r\n                <div class=\"project-item\">Mobile Game</div>\r\n            </div>\r\n        </section>\r\n\r\n        <section class=\"resources\">\r\n\r\n            <h3>📚 Free Learning Resources</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://learn.unity.com/\" target=\"_blank\">Unity Learn</a></li>\r\n\r\n                <li><a href=\"https://www.unrealengine.com/en-US/onlinelearning-courses\" target=\"_blank\">Unreal Online\r\n                        Learning</a></li>\r\n\r\n                <li><a href=\"https://www.gamedev.net/\" target=\"_blank\">GameDev.net</a></li>\r\n\r\n                <li><a href=\"https://itch.io/\" target=\"_blank\">Itch.io - Game Jam Community</a></li>\r\n\r\n                <li><a href=\"https://www.gamedeveloper.com/\" target=\"_blank\">Game Developer Magazine</a></li>\r\n            </ul>\r\n\r\n            <h3>🎥 Free Video Tutorials</h3>\r\n\r\n            <ul>\r\n                <li><a href=\"https://www.youtube.com/@Brackeys\" target=\"_blank\">Brackeys</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@CodeMonkey\" target=\"_blank\">Code Monkey</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@UnrealEngine\" target=\"_blank\">Unreal Engine Official</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@GameDev\" target=\"_blank\">Game Dev</a></li>\r\n\r\n                <li><a href=\"https://www.youtube.com/@Pixelated\" target=\"_blank\">Pixelated</a></li>\r\n            </ul>\r\n\r\n        </section>\r\n\r\n        <!-- ============ FAQ ============ -->\r\n        <section id=\"faq\">\r\n            <h2>Frequently Asked Questions</h2>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What's the difference between Game Developer and Game Designer?</h4>\r\n                <p>Game Developer writes code and implements systems. Game Designer creates the vision and gameplay\r\n                    mechanics. Developers build it, Designers design it.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Should I learn Unity or Unreal Engine?</h4>\r\n                <p>Unity is easier to start with and great for 2D/mobile. Unreal is more powerful for 3D/AAA games.\r\n                    Start with Unity, then explore Unreal if interested.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Do I need to be good at art to be a game developer?</h4>\r\n                <p>No. There are artists, animators, and sound designers on a team. You focus on programming and\r\n                    systems. You can use free art assets to learn.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Can I make money developing indie games?</h4>\r\n                <p>Yes! Many indie developers make money through Steam, itch.io, app stores. Some make full-time income.\r\n                    Others do it as a hobby alongside day jobs.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>How long does it take to develop a game?</h4>\r\n                <p>2D indie game: 3-6 months. 3D indie game: 1-2 years. AAA game: 3-5+ years with a large team. Depends\r\n                    on scope and complexity.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>Do I need a degree to become a game developer?</h4>\r\n                <p>No. Many successful developers are self-taught. What matters is your portfolio and skills. Build\r\n                    games and showcase them on GitHub and itch.io.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What programming language should I learn first?</h4>\r\n                <p>C# for Unity (easier to learn). C++ for Unreal (more powerful). Python for game scripting and\r\n                    automation. Start with C#, it's more beginner-friendly.</p>\r\n            </div>\r\n\r\n            <div class=\"faq-item\">\r\n                <h4>What's the salary range for game developers in India?</h4>\r\n                <p>Fresher: ₹3-6 LPA. 2-3 years: ₹8-12 LPA. 5+ years: ₹15-25 LPA. Senior leads: ₹25-40+ LPA. Depends on\r\n                    company size and location.</p>\r\n            </div>\r\n        </section>\r\n\r\n    </div>\r\n\r\n    <!-- ============ FOOTER ============ -->\r\n    <footer class=\"footer\">\r\n        <div class=\"footer-container\">\r\n\r\n            <div class=\"footer-box\">\r\n                <div class=\"U\">\r\n                    <h2>Tech Career</h2>\r\n                    <p>\r\n                        Discover technology careers, explore learning paths,\r\n                        and build your future in the tech industry.\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Quick Links</h3>\r\n                <ul>\r\n                    <li><a href=\"index.html\">➤ Home</a></li>\r\n                    <li><a href=\"index.html\">➤ Careers</a></li>\r\n                    <li><a href=\"index.html\">➤ Roadmaps</a></li>\r\n                    <li><a href=\"index.html\">➤ Resources</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"footer-box\">\r\n                <h3>Specializations</h3>\r\n                <ul>\r\n                    <li><a href=\"web-development.html\">➤ Web Development</a></li>\r\n                    <li><a href=\"mobile-development.html\">➤ Mobile Development</a></li>\r\n                    <li><a href=\"AIML.html\">➤ AI & ML</a></li>\r\n                    <li><a href=\"data-Analytics.html\">➤ Data & Analytics</a></li>\r\n                    <li><a href=\"UX_UX.html\">➤ UI/UX Design</a></li>\r\n                    <li><a href=\"cyber.html\">➤ Cybersecurity</a></li>\r\n                    <li><a href=\"cloud&DevOps.html\">➤ Cloud & DevOps</a></li>\r\n                    <li><a href=\"game-de.html\">➤ Game Development</a></li>\r\n                </ul>\r\n            </div>\r\n\r\n           <div class=\"footer-box\">\r\n                <h3>Contact</h3>\r\n                <ul>\r\n                    <li><i class=\"fa-solid fa-envelope\"></i> : <a\r\n                            href=\"mailto:rk8938273@gmail.com\" target=\"_blank\">rk8938273@gmail.com</a></li>\r\n                    <li><i class=\"fa-solid fa-phone\"></i> : <a href=\"tel:+919876543210\"  target=\"_blank\">+91 9876543210</a></li>\r\n                    <li><i class=\"fa-brands fa-github\"></i> : <a href=\"https://github.com/Ravindra1807\"  target=\"_blank\">Ravindra1807</a>\r\n                    </li>\r\n                    <li><i class=\"fa-brands fa-linkedin\"></i> : <a\r\n                            href=\"https://www.linkedin.com/in/ravindra-kumar-a95761385\" target=\"_blank\">Ravindra Kumar</a></li>\r\n                </ul>\r\n            </div>\r\n        </div>\r\n\r\n        <div class=\"footer-bottom\">\r\n            <p>© 2026 Tech Career Explorer. All Rights Reserved. | Developed by Ravindra Kumar</p>\r\n        </div>\r\n    </footer>\r\n\r\n    <script>\r\n        const menuBtn = document.querySelector(\".menu-btn\");\r\n        const navLinks = document.querySelector(\"#navLinks\");\r\n        const dropdowns = document.querySelectorAll(\".dropdown\");\r\n\r\n        // Mobile hamburger toggle\r\n        menuBtn.addEventListener(\"click\", (e) => {\r\n            e.stopPropagation();\r\n            navLinks.classList.toggle(\"active\");\r\n        });\r\n\r\n        // Close navbar + all dropdowns on outside click\r\n        document.addEventListener(\"click\", (e) => {\r\n            if (!navLinks.contains(e.target) && !menuBtn.contains(e.target)) {\r\n                navLinks.classList.remove(\"active\");\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n            }\r\n        });\r\n\r\n        // Dropdown toggle — 1 click open, same click close\r\n        dropdowns.forEach((dropdown) => {\r\n            const toggle = dropdown.querySelector(\".dropdown-toggle\");\r\n\r\n            toggle.addEventListener(\"click\", (e) => {\r\n                e.preventDefault();\r\n                e.stopPropagation();\r\n\r\n                const isOpen = dropdown.classList.contains(\"open\");\r\n\r\n                // close all first\r\n                dropdowns.forEach((d) => d.classList.remove(\"open\"));\r\n\r\n                // toggle this one\r\n                if (!isOpen) dropdown.classList.add(\"open\");\r\n            });\r\n        });\r\n\r\n        // Clicks inside dropdown-menu don't close it\r\n        document.querySelectorAll(\".dropdown-menu\").forEach((menu) => {\r\n            menu.addEventListener(\"click\", (e) => e.stopPropagation());\r\n        });\r\n    </script>\r\n\r\n</body>\r\n\r\n</html>"
